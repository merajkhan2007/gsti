					tElement.html(interpolatedHtml);
				}
				return link;
			}
		};
    }
]);

myApp.directive('autoDropdown', ['$q', '$parse', '$http', '$sce', '$timeout', '$templateCache', '$interpolate', '$window', 'shareData', '$location',

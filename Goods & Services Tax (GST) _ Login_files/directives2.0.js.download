        var KEY_DW = 40,
            KEY_RT = 39,
            KEY_UP = 38,
            KEY_LF = 37,
            KEY_ES = 27,
            KEY_EN = 13,
            MIN_LENGTH = 3,
            BLUR_TIMEOUT = 200,
            TEMPLATE_URL = '/pages/registration/autocompleteGoodsServices.html';

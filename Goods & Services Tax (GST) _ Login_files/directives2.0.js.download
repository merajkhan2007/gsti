						params: {
							"q": str
						}
					},
					url = scope.remoteUrl;
          	var apiURL = url + str;
                if(scope.firstParam && scope.secondParam){
                    apiURL = url  + '?' + 'inputText=' + str + '&'+ scope.firstParam + '&' + scope.secondParam;

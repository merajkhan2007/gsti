myApp.directive("readjson", [function () {
	return {
		scope: {
			readjson: "="
		},
		link: function (scope, element, attributes) {
			element.bind("change", function (changeEvent) {
				scope.readjson=null;
				var reader = new FileReader();
				reader.onload = function (loadEvent) {
					scope.$apply(function () {
						try {
							scope.readjson = JSON.parse(loadEvent.target.result);
						} catch(e) {
							console.log("Exception occured while uploading file, excpetion is "+e);
							 return '';
						}
					});
				}
				reader.readAsText(changeEvent.target.files[0]);
			});
		}
	}
}]);


myApp.directive('jsTree', ['$http', function ($http) {

	var treeDir = {
		restrict: 'EA',
		fetchResource: function (url, cb) {
			return $http.get(url).then(function (data) {
				if (cb) cb(data.data);
			});
		},

		managePlugins: function (s, e, a, config) {
			if (a.treePlugins) {
				config.plugins = a.treePlugins.split(',');
				config.core = config.core || {};
				config.core.check_callback = config.core.check_callback || true;

				if (config.plugins.indexOf('state') >= 0) {
					config.state = config.state || {};
					config.state.key = a.treeStateKey;
				}

				if (config.plugins.indexOf('search') >= 0) {
					var to = false;
					if (e.next().attr('class') !== 'ng-tree-search') {
						e.after('<input type="text" placeholder="Search Tree" class="ng-tree-search"/>')
							.next()
							.on('keyup', function (ev) {
								if (to) {
									clearTimeout(to);
								}
								to = setTimeout(function () {
									treeDir.tree.jstree(true).search(ev.target.value);
								}, 250);
							});
					}
				}

				if (config.plugins.indexOf('checkbox') >= 0) {
					config.checkbox = config.checkbox || {};
					config.checkbox.keep_selected_style = false;
				}

				if (config.plugins.indexOf('contextmenu') >= 0) {
					if (a.treeContextmenu) {
						config.contextmenu = s[a.treeContextmenu];
					}
				}

				if (config.plugins.indexOf('types') >= 0) {
					if (a.treeTypes) {
						config.types = s[a.treeTypes];
					}
				}

				if (config.plugins.indexOf('dnd') >= 0) {
					if (a.treeDnd) {
						config.dnd = s[a.treeDnd];
					}
				}
			}
			return config;
		},
		manageEvents: function (s, e, a) {
			if (a.treeEvents) {
				var evMap = a.treeEvents.split(';');
				for (var i = 0; i < evMap.length; i++) {
					if (evMap[i].length > 0) {
						// plugins could have events with suffixes other than '.jstree'
						var evt = evMap[i].split(':')[0];
						if (evt.indexOf('.') < 0) {
							evt = evt + '.jstree';
						}
						var cb = evMap[i].split(':')[1];
						treeDir.tree.on(evt, s[cb]);
					}
				}
			}
		},
		link: function (s, e, a) { // scope, element, attribute \O/
			$(function () {
				var config = {};

				// users can define 'core'
				config.core = {};
				if (a.treeCore) {
					config.core = $.extend(config.core, s[a.treeCore]);
				}

				// clean Case
				a.treeData = a.treeData ? a.treeData.toLowerCase() : '';
				a.treeSrc = a.treeSrc ? a.treeSrc.toLowerCase() : '';

				if (a.treeData == 'html') {
					treeDir.fetchResource(a.treeSrc, function (data) {
						e.html(data);
						treeDir.init(s, e, a, config);
					});
				} else if (a.treeData == 'json') {
					treeDir.fetchResource(a.treeSrc, function (data) {
						config.core.data = data;
						treeDir.init(s, e, a, config);
					});
				} else if (a.treeData == 'scope') {
					s.$watch(a.treeModel, function (n, o) {
						if (n) {
							config.core.data = s[a.treeModel];
							$(e).jstree('destroy');
							treeDir.init(s, e, a, config);
						}
					}, true);
					// Trigger it initally
					// Fix issue #13
					config.core.data = s[a.treeModel];
					treeDir.init(s, e, a, config);
				} else if (a.treeAjax) {
					config.core.data = {
						'url': a.treeAjax,
						'data': function (node) {
							return {
								'id': node.id != '#' ? node.id : 1
							};
						}
					};
					treeDir.init(s, e, a, config);
				}
			});

		},
		init: function (s, e, a, config) {
			treeDir.managePlugins(s, e, a, config);
			this.tree = $(e).jstree(config);
			treeDir.manageEvents(s, e, a);
		}
	};

	return treeDir;

}]);
myApp.filter('to_trusted', ['$sce', function ($sce) {
	return function (text) {
		return $sce.trustAsHtml(text);
	};
}]);
myApp.directive('highlight', function() {
	var component = function(scope, element, attrs) {
		
		if (!attrs.highlightClass) {
			attrs.highlightClass = 'text-highlight';
		}
		
		var replacer = function(match, item) {
			return '<span class="'+attrs.highlightClass+'">'+match+'</span>';
		}
		var tokenize = function(keywords) {
			keywords = keywords.replace(new RegExp(',$','g'), '').split(',');
			var i;
			var l = keywords.length;
			for (i=0;i<l;i++) {
				keywords[i] = keywords[i].replace(new RegExp('^ | $','g'), '');
			}
			return keywords;
		}
		
		scope.$watch('keywords', function() {
			//console.log("scope.keywords",scope.keywords);
			if (!scope.keywords || scope.keywords == '') {
				element.html(scope.highlight);
				return false;
			}
			
			
			var tokenized	= tokenize(scope.keywords);
			var regex 		= new RegExp(tokenized.join('|'), 'gmi');
			
			//console.log("regex",regex);
			
			// Find the words
			var html = scope.highlight.replace(regex, replacer);
			
			element.html(html);
		});
	}
	return {
		link: 			component,
		replace:		false,
		scope:			{
			highlight:	'=',
			keywords:	'='
		}
	};
});

myApp.directive('dropdownBtn', function (ajax,$rootScope) {
    return {
        restrict: "E",
        scope: {
            btnName: "@",
            callBack: "&",
            url:'@',
            params:'=',
            clickedValue:"=",
            option:'='
        },
        link:function(scope, element, attrs){
            scope.options = [];
            scope.toggle = function() {
                scope.showContent = !scope.showContent;
            };
            scope.buttonClick = function(a){
                scope.clickedValue = scope.options[a];
                scope.callBack({type: a});
            };
            if(scope.option)
                scope.options = scope.option;
            else
            ajax.post(scope.url,scope.params).then(function(response){
                scope.options = response;
                !scope.$$phase && scope.$apply();
            });
             window.onclick = function(event) {
            if (!event.target.matches('.dropbtn') && !event.target.matches('.dropdwnSpan')) {
                var dropdowns = document.getElementsByClassName("dropdown-content");
                var i;
                for (i = 0; i < dropdowns.length; i++) {
                var openDropdown = dropdowns[i];
                if (openDropdown.classList.contains('show')) {
                    openDropdown.classList.remove('show');
                }
                }
            }
            };
        },
        template: '<div class="dropdowngrp"><button ng-click="toggle()" class="btn btn-primary dropbtn"><span class="dropdwnSpan" ng-bind="btnName"></span>&nbsp;<span class="caret dropdwnSpan"></span></button><div id="myDropdown" class="dropdown-content" ng-class="{\'show\': showContent}"><a role="button" ng-repeat="(key,value) in options" ng-click="buttonClick(key)" ng-bind="value"></a></div></div>'
    };
});
myApp.directive('downloadDoc', function() {
    return {
        restrict: 'A',
        scope: {
            url: '=',
			hashkey: '=',
			arn: '=',
			mod: '='
        },
        link: function(scope, ele, attr) {
            var eventName = attr.evetName || 'click';
            ele.on(eventName, function() {
                var isIE = false;
                if (navigator.userAgent.indexOf('Trident/') != '-1') { isIE = true; }

                //Cheking if IE browser then create element "a"
                if (isIE) {
                    var referLink = document.createElement('a');
                    referLink.href = scope.url + scope.hashkey;
                    referLink.target = "_blank";
                    referLink.click();
                } else {
					open(scope.url + scope.hashkey + '&arn=' + scope.arn + '&mod=' + scope.mod, '_blank');
                }
            });
        }
    };
});

myApp.directive('downloadDocSecure', function() {
    return {
        restrict: 'A',
        scope: {
            url: '=',
			hashkey: '=',
			arn: '=',
			ekey: '=',
			mod: '='
        },
        link: function(scope, ele, attr) {
            var eventName = attr.evetName || 'click';
            ele.on(eventName, function() {
                var isIE = false;
                if (navigator.userAgent.indexOf('Trident/') != '-1') { isIE = true; }

                //Cheking if IE browser then create element "a"
                if (isIE) {
                    var referLink = document.createElement('a');
					if(scope.mod != undefined && scope.mod != ''){
						referLink.href = scope.url + scope.hashkey + '&arn=' + scope.arn + '&eh=' + scope.ekey + '&mod=' + scope.mod;
					}
					else if((scope.arn != undefined && scope.arn != '') && (scope.ekey != undefined && scope.ekey != '')){
                    referLink.href = scope.url + scope.hashkey + '&arn=' + scope.arn + '&eh='+ scope.ekey;
					} else if(scope.arn != undefined && scope.arn != ''){
                        referLink.href = scope.url + scope.hashkey + '&arn=' + scope.arn;
					} else {
						referLink.href = scope.url + scope.hashkey;
					}
                    referLink.target = "_blank";
                    referLink.click();
                } else {
					if(scope.mod != undefined && scope.mod != ''){
						open(scope.url + scope.hashkey + '&arn=' + scope.arn + '&eh=' + scope.ekey + '&mod=' + scope.mod, '_blank')
					}
					else if((scope.arn != undefined && scope.arn != '') && (scope.ekey != undefined && scope.ekey != '')){
                    open(scope.url + scope.hashkey + '&arn=' + scope.arn + '&eh='+ scope.ekey, '_blank')
					} else if(scope.arn != undefined && scope.arn != ''){
                        open(scope.url + scope.hashkey + '&arn=' + scope.arn, '_blank')
					} else {
						open(scope.url + scope.hashkey)
					}
					
                }
            });
        }
    };
});

myApp.directive('timepickerfull', function () {
	return {
		require: '?ngModel',
		scope : {
			"minDays" : "=" ,
			"maxDays" : "=" 
		},
		link: function (scope, element, attrs, ctrl) {
			$(element).datetimepicker({
				format:"DD/MM/YYYY HH:mm:ss",
				icons: {
                    time: "fa fa-clock-o",
                    date: "fa fa-calendar",
                    up: "fa fa-arrow-up",
					down: "fa fa-arrow-down",
					next: 'fa fa-angle-right',
					previous: 'fa fa-angle-left'
				},
				minDate:moment().subtract(scope.minDays, 'days').millisecond(0).second(0).minute(0).hour(0),
  				maxDate:moment().add(scope.maxDays, 'days').second(59).minute(59).hour(23)
			});
			element.on("paste", function (e) {
				e.preventDefault();
			})
			element.on('dp.change', function(event) {
                scope.$apply(function() {
                    ctrl.$setViewValue($(event.target).val());
                });
            });
			element.on('blur', function (event) {
                scope.$apply(function () {
                    ctrl.$setViewValue($(event.target).val());
                });
            });
		}
	};
});
myApp.directive('attachStak', ['ajax', '$compile', '$timeout', 'utilFunctions', '$filter', 'FormSubmitter', function(ajax, $compile, $timeout, utilFunctions, $filter, FormSubmitter) {

    function link(scope, elem, attrs) {
        scope.submit = function() {
            if (scope.submitCk()) {
                //checking form completion
                scope.callStak();
            }
        };
        // scope.stakDisableMsg = "To file using STAK, Register on STAK APP mobile application and activate it from my profile section on GST Portal";
        //changing button label
        if (scope.formvalue) {
            scope.stakBtnValue = "File with Stak";
        } else {
            scope.stakBtnValue = "File with Stak";
        }

        scope.setErr = function(msg, type) {
            switch (type) {
                case "error":
                    scope.errtype = "danger";
                    break;
                case "warning":
                    scope.errtype = "warning";
                    break;
                case "success":
                    scope.errtype = "success";
                    break;
            }
            if (msg == "") {
                delete scope.err;
            } else {
                scope.err = msg;
            }
        };
        scope.validateStak = true;
        scope.checktOtp = function(){

            if(scope.totp.length == '6'){
            scope.validateStak = false;
            }
            else {
                scope.validateStak = true;
            }
        }
        scope.verifyStak = function() {
            if (!scope.totp || scope.totp == '') {
                scope.setErr("Please enter OTP", 'error');
                return;
            } 
            else if (!/^\d*\.?\d*$/.test(scope.totp)) {
                scope.setErr("Invalid OTP entered", 'error');
                return;
            } 
            else {
                scope.setErr("");
            }

            ajax.post(scope.signUrl, {
                    "tOtp": scope.totp,
                    "returnType": scope.formType,
                    "pan": scope.pan,
                    "deviceId": scope.deviceid,
                    "mobileNum": scope.mobileno,
                    "uuid": scope.uuid,
                    "gstin": scope.gstin
                    
                }, {}, function() {
                    scope.setErr("Please wait, validating OTP..", 'warning');
                    }).then(function(resp) {
                    if (resp.status_cd == "0") {
						if(resp.error.error_cd == "STAK_ER_12"){
							scope.setErr('The STAK you have entered is incorrect or expired. ' + resp.error.message + ' You shall be blocked for the day thereafter.', 'error');
						}
						else if(resp.error.error_cd == "1001"){
							scope.setErr('Internal Server Error.', 'error');
						}
						else if(resp.error.error_cd == "1002" || resp.error.error_cd == "STAK_ER_1009"){
							scope.setErr('This mobile number is not activated for STAK. Kindly activate it from My Profile section in GST Portal.', 'error');
						}
						else if(resp.error.error_cd == "1004"){
							scope.setErr('This mobile number is not activated for STAK. Kindly activate it from My Profile section in GST Portal.', 'error');
						}
						else if(resp.error.error_cd == "1005"){
							scope.setErr('The device id has been changed. Please deactivate the existing device and activate AS again to refresh the latest device id.', 'error');
						}
						else if(resp.error.error_cd == "1010"){
							scope.setErr('Due to 5 incorrect attempts, you have been blocked to use the STAK verification for the day. Kindly use EVC/ DSC for verification.', 'error');
							scope.validateStak = true;
						}
						else{
							scope.reset();
							scope.setErr("Unable to submit form. Please try again.", 'error');
						}
                       
                    } 
					// else if (resp.stscd == "1" || resp.stscd == "SUCCESS") {
                    //     scope.reset();
                    //     scope.callBack({
                    //         'data': resp
                    //     });
                    // } 
					else {
                        scope.reset();
                        //resp = { errorCd: "DSCEVC502", stscd: "0", message: "Your OTP is expired please try again" };
                        scope.callBack({
                            'data': resp
                        });
                    }
                }, function() {
                    scope.reset();
                    scope.setErr("Unable to submit form. Please try again.", 'error');
                })
            };

     scope.reset = function() {
            scope.totp = "";
            $("#otpPrompt1").modal('hide');
            $(".modal-backdrop").remove();
        };

        $("#otpinput1").keypress(function(e){
            e.stopPropagation();
            });
            $("#otpinput1").keydown(function(e){
            e.stopPropagation();
            });
            
        scope.callStak = function() {
            scope.validateStak = true;
            if (scope.deviceid) {
                scope.deviceID = scope.deviceid.substr(0, 2) + utilFunctions.maskString(scope.deviceid.substr(2, scope.deviceid.length-2), 'prepend') + scope.deviceid.substr(scope.deviceid.length-2, scope.deviceid.length);
            }
            if (scope.mobileno) {
                scope.mobile = scope.mobileno.substr(0, 2) + utilFunctions.maskString(scope.mobileno.substr(2, 6), 'prepend') + scope.mobileno.substr(8, 10);
            }
            $timeout(function() {
                $("#otpinput1").focus();
            }, 400);
            $("#otpPrompt1").modal({
                show: true,
                backdrop: 'static'
            });
			if(scope.deviceid == "undefined" || scope.deviceid == "null" || scope.mobileno == "undefined" || scope.mobileno == "null"){
				
			}

			else {
            scope.setErr("Enter the six-digit STAK key available on your STAK mobile application installed on device id " + scope.deviceID + " with mobile number " + scope.mobile + ".", 'success');
			}
        };

        
    }
    return {
        restrict: 'A',
        scope: {
            "signUrl": "@",
            "rPayload": "@",
            "callBack": "&",
            "submitCk": "&",
            "formType": "@",
            "tranId": "@",
            "username": "@",
            "mobileno": "@",
            "stCode": "@",
            "uuid": "@",
            "userBlkStatus": "@",
            "deviceid": "@",
            "formvalue": "@",
            "pan": "@",
            "gstin": "@",
            "disablestak": "@",
           "captchaValue": "=",
		   "hovermsg": "@"
           
        },
        compile: function(tElement) {
            return link;
        },

        template: function(ele, attrs, scope) {
            return "<button type='button' title = \"{{disablestak == 'true' ? hovermsg : ''}}\" data-ng-disabled = \"disablestak == 'true'\" class='btn btn-primary' data-ng-click='submit()'>{{stakBtnValue}}</button><div id='otpPrompt1' class='modal fade text-left' role='dialog'><div class='modal-dialog'><div class='modal-content'><div class='modal-header'><h4 class='modal-title'>STAK Verification</h4></div><div class='modal-body'><div class='alert alert-{{errtype}} rowtp-mar' data-ng-if='err'><p data-ng-bind='err'></p></div><label class='reg m-cir'>Enter STAK</label><form novalidate><input type='password' name='totp' id='otpinput1' class='form-control upper-input' data-capitalize='' data-ng-model='totp' maxlength='6' data-ng-change = 'checktOtp()' autofocus></form></div><div class='modal-footer'><button type='button' class='btn btn-default' data-ng-click='reset()'>Cancel</button><button type='button' data-ng-click='verifyStak()' data-ng-disabled = 'validateStak' class='btn btn-primary'>Validate STAK</button> </div><div class='row'style='padding: 15px;margin-top: -25px !important;' ><div class='col-sm-12 xs-12'></div></div></div></div></div>";
        }
    };
}]);
		return {
			restrict: 'EA',
			//require: '^?form',
			scope: {
				dataObject: '=',
				id: '@',
				type: '@',
				placeholder: '@',
				remoteUrl: '@',
				titleField: '@',
				descriptionField: '@',
				pause: '@',
				minlength: '@',
				matchClass: '@',
				inputName: '@',
				afterSelect: '&',
				resetResults: '&',
				clearResultAfterSelect: '@',
				localData: '=',
				viewAllUrl: '@',
				showViewAll: '@',
				disableAfterSelect: '@',

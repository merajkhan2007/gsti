        }
	};
});

myApp.directive('revokeAuthDialogue', function() {
    return {
        restrict: "E",
        scope: {
            title: "@",
            message: "@",
            submsg: "@",
            callback: "&",
            okTitle: "@",
            viewskipbtn: "@"
        },
        template: function(attrs) {
            var isNewPopup = attrs[0].attributes[0].nodeValue;
            if (isNewPopup) {
                var output = 
                '<div id="confirmDlg" class="modal fade fade-scale" role="dialog">' +
                    '<div class="modal-dialog sweet" style="width:75% !important">' +
                        '<div class="modal-content">' +
                            '<div class="modal-body" style = "padding: 40px 40px 0px 40px;">' +
                                '<p class="text-justify" style="align-items: center;flex-direction: column;justify-content: center;display: flex;">{{message}} <span class="break-here" style="display: block;">If you wish to continue, kindly enter the valid reason and click on Revoke button.</span></p>' +
                                '<div class="form-group" style="display:flex; width: 100%; gap: 1rem; justify-content: center; align-items: center;">' +
                                    '<label for="revokeReason" style="font-weight:normal">Reason for revoke</label>' +
									'<input id="revokeReason" ng-model="revokeReason" maxlength="500" placeholder="Please specify the reason for revoke(maximum 500 characters)" style="width:75%; height:48px; display:flex; align-items:center; vertical-align:middle;" />' +
                                '</div>' +
                            '</div>' +
                            '<div class="modal-footer">' +
                                '<a class="btn btn-default" style="width: 18rem;" data-dismiss="modal" ng-click="clearReason()" target="_blank">CANCEL</a>' +
                                '<a class="btn btn-primary" style="width: 18rem;" ng-click="onOk()" target="_blank">{{okTitle}}</a>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                '</div>';
                return output;
            }
        },
        link: function(scope, element, attrs) {
            $('#confirmDlg').on('shown.bs.modal', function() {
                $(this).find('button[id="okTitle"]').focus();
            });
            scope.clearReason = function() {
                scope.revokeReason = '';
            };
            scope.onOk = function() {
                scope.callback({revokeReason: scope.revokeReason});
                scope.revokeReason = '';
            };
        }
    };
});

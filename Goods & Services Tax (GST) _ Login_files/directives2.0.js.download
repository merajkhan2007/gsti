myApp.directive('finalApprovedTurnover', function () {
	return {
		restrict: "E",
		controllerAs: 'dir',
		scope: {
			data: "=",
			callback: "&",
			cancelcallback: "&",
			sendvfyreqbtnTitle: "@",
			rmdbtnTitle: "@"
		},
		template: '<style>.w-10 {width: 8%}.w-35 {width: 25%}.w-45 {width: 45%}.txtAlign {text-align: right}</style><div id="finturnoverSumtable" class="modal fade fade-scale" role="dialog"><div class="modal-dialog modal-lg sweet"><div class="modal-content pdfPopupScroll"><div class="modal-header"><button type="button" class="close" data-dismiss="modal">×</button></div><div class="modal-body"><div><div class="turnoverContainer"><h4 class="tlt1">Statement of Turnover for a Financial Year</h4><div class="tableContainer"><div><table class="table table-striped table-bordered finClass"><tr><td>Financial Year</td><td> {{data.fy}}</td></tr></table></div><div class=""><table class="table table-striped table-bordered"><tr><td class="w-10">1.</td><td class="w-35">GSTIN</td><td> {{data.gstin}}</td></tr><tr><td>2.(A)</td><td>Legal name</td><td colspan="14"> {{data.legName || "-"}}</td></tr><tr><td>2.(B)</td><td>Trade name,if any</td><td colspan="14"> {{data.tradeName || "-"}}</td></tr></table></div><div><h4 class="subHeadCls"><span>3. </span>Turnover of the Financial Year for the GSTIN above</h4><div style="text-align: right;">(Amount in ₹ in tables)</div><div class="table-responsive"><table class="table table-striped table-bordered turnoverTable"><tr><td class="w-10">(i)</td><td class="w-35">System computed Turnover</td><td style="text-align: right;"> {{data.gstinSysTo.toPrecision() | currency: " " }}</td><td>As on Date : {{data.finalToDate}}</td></tr><tr><td>(ii)</td><td>Reported by Taxpayer</td><td style="text-align: right;"> {{data.gstinuserTo.toPrecision() | currency: " "}}</td><td><div><p>ARN : {{data.arn || "-" }} </p><p>ARN Date : {{data.arnDate || "-" }} </p></div></td></tr><tr><td>(iii)</td><td>Updated by Tax-Officer</td><td style="text-align: right;"> {{data.gstinOffUpdatedTo.toPrecision() | currency: " "}}</td><td><div><p>Reference Number : {{data.refNum || "-" }} </p><p>Reference Date : {{data.refDate || "-"}} </p></div></td></tr><tr><td>(iv)</td><td><div><p>Tax Officer Details</p></div></td><td colspan="2"><div><p> Name : {{data.toName || "-"}} </p><p> Designation : {{data.toDegination || "-" }}</p><p> Jurisdiction : {{data.toJur || "-"}} </p></div></td></tr><tr><td>(v)</td><td>Final Turnover</td><td style="text-align: right;">{{ (data.gstinFinalTo != null ) ? (data.gstinFinalTo.toPrecision() | currency: " ") : "-"}}</td><td>As on Date : {{data.displayToDate}}</td></tr></table></div></div><div><h4 class="subHeadCls"><span>4.</span>Aggregate Turnover(PAN Based)</h4><div class="table-responsive"><table class="table table-striped table-bordered aggturnoverTable"><tr><td class="w-10">Sr.No</td><td class="w-45">Description</td><td>Number/Amount</td></tr><tr style="text-align: center;"><td>(1)</td><td>(2)</td><td>(3)</td></tr><tr><td>1.</td><td>No. of registrations on the same PAN across the country</td><td class="txtAlign">{{data.noOfTp}}</td></tr><tr><td>2.</td><td>Out of (1) above, No. of Taxpayers who have filed all returns as on {{data.finalToDate}}</td><td class="txtAlign">{{data.noOfFiledTp}}</td></tr><tr><td>3.</td><td>Out of (1) above, No. of registration(s) who have updated the Turnover as on {{data.finalToDate}}</td><td class="txtAlign">{{data.noOfTpUpdatedTo}}</td></tr><tr><td>4.</td><td>System Computed Aggregate Turnover as on {{data.finalToDate}}</td><td class="txtAlign">{{(data.aggSysTo != null) ? (data.aggSysTo.toPrecision() | currency : " ") : "-"}}</td></tr><tr><td>5.</td><td>Aggregate Turnover based on Taxpayer’s inputs as on {{data.finalToDate}}</td><td class="txtAlign">{{(data.aggUserTo != null) ? (data.aggUserTo.toPrecision() | currency : " ") : "-"}}</td></tr><tr><td>6.</td><td>Aggregate Turnover based on Tax-officers review as on {{data.displayToDate}}</td><td class="txtAlign">{{(data.aggOffTo != null) ? (data.aggOffTo.toPrecision() | currency : " ") : "-"}}</td></tr><tr><td>7.</td><td>Final Aggregate Turnover {{data.displayToDate}}</td><td class="txtAlign">{{(data.aggFinalTo != null) ? (data.aggFinalTo.toPrecision() | currency : " ") : "-"}}</td></tr></table></div></div><div><div style="font-weight: bold;"><span style="text-decoration: underline;">Disclaimer:</span><span> This is a system generated pdf and it requires no signing.</span></div><br/><div style="font-weight: bold;"><span style="text-decoration: underline;">Note: Last updated on - {{data.displayToDate}}</span></div></div></div></div></div></div><div class="modal-footer"><div class="row"><a class="btn btn-primary" ng-click="callback()">Download</a></div></div></div></div></div>',
	};
});

/*jslint browser: true, sloppy:true, nomen: true, node: true, bitwise: true, regexp: true*/
/*global $, jQuery, angular, myApp, regex, transctrl, accessctrl, translationSrv, RouteProviderConfig, moment, WebSocket, Uint8Array, FileReader, MediaStreamTrack, console, getComputedStyle, FormData*/

"use strict";
if (!myApp) {
	var myApp = angular.module("myApp", ['ngRoute', 'LocalStorageModule', 'ngProgress']);
	var RouteProviderConfig = function ($routeProvider, $locationProvider) {

	}
}
myApp.controller("alertCtrl", ["$scope", "$rootScope", "$timeout", "NgTableParams", "ajax", "$window", "ngTableEventsChannel", function ($scope, $rootScope, $timeout, NgTableParams, ajax, $window, ngTableEventsChannel) {
	
	$scope.alert = {}; 
	$scope.onLoad = function () {
		ajax.post("/services2/auth/web/alerts/count",{}).then(function (response) {
			if (response) {
				$scope.alert.info = response;
			}
		});
	};

	$scope.markAsRead = function(alertID) {

		$scope.request = {};
		$scope.array = [];
		$scope.array.push(alertID);
		$scope.request = {
			"alertId":$scope.array,
			"read": "Y"
		}

		ajax.post("/services2/auth/web/alerts/update", $scope.request).then(function (response) {
			console.log(response);
			$window.location.href = "/services/auth/viewallalerts";
		}, function (err) {
			console.log(err);
			$window.location.href = "/services/auth/viewallalerts";
		});
	}



	$scope.listOfAlertsToUpdate = [];

	function clear() {
		$scope.listOfAlertsToUpdate.length = 0;
	}

	$scope.showAllAlerts = function() {
		//var pagesChangedEvent = _.partial(updateEvent);
		ngTableEventsChannel.onPagesChanged(function updateEvent() {

			clear();
			$scope.alert.index = ($scope.alertsTable.page() - 1 )*$scope.alertsTable.count();
			for (var i=$scope.alert.index; 
				i < (($scope.alert.index + $scope.alertsTable.count()) > $scope.alert.allAlerts.alerts.length ? $scope.alert.allAlerts.alerts.length : ($scope.alert.index + $scope.alertsTable.count())); 
				i++){
					
				if($scope.alert.allAlerts.alerts[i].isRead !== "Y"){
					$scope.listOfAlertsToUpdate.push($scope.alert.allAlerts.alerts[i].alertId);
				}
			}
			console.log($scope.listOfAlertsToUpdate);
			$scope.request = {
				"alertId": $scope.listOfAlertsToUpdate,
				"read": "Y"
			}
	
			ajax.post("/services2/auth/web/alerts/update", $scope.request).then(function (response) {
				console.log(response);
			}, function (err) {
			});
		}, $scope);

		ajax.post("/services2/auth/web/alerts/all",{}).then(function (response) {
			if (response) {
				$scope.alert.allAlerts = response;
			}

			if ($scope.alert.allAlerts && $scope.alert.allAlerts.alerts.length > 0){

				$scope.alertsTable = new NgTableParams({
					page: 1,
					count: 5,
					sorting: {
						alertId: 'desc'
					}
				}, {
					counts: [],
					dataset: $scope.alert.allAlerts.alerts
		
				});
			}
		});
	}
}]).controller("footerCtrl", ["$scope", "$rootScope", function ($scope, $rootScope) {
	$rootScope.$on("udata", function (event, mass) {
		if (mass && mass.udata) {
			$scope.udata = mass.udata;
			$scope.expanded = true;
		}
	});
	$scope.expanded = false;
	$scope.servers = $().getConstant('servers');
	$scope.fexpand = function () {
		$scope.expanded = !$scope.expanded;
	};
	const year = new Date().getFullYear();
	const month = new Date().getMonth() + 1;
	$scope.FY = month > 3 ? `${year}-${(year + 1).toString().slice(2,4)}` : `${year - 1}-${year.toString().slice(2,4)}`;
	
}]).controller("headerCtrl", ["$scope", "ajax", "$timeout", "shareData", "$rootScope", "$route", "utilFunctions", "$compile", "cache", "$location", "FormSubmitter", function ($scope, ajax, $timeout, shareData, $rootScope, $route, utilFunctions, $compile, cache, $location, FormSubmitter) {
	$scope.udata = undefined;
	$scope.servers = $().getServers();
	//adding for masking cr17153
	
	 // IMS link enable and disble with live date
	 var today = new Date();
	 var dd = String(today.getDate()).padStart(2, "0");
	 var mm = String(today.getMonth() + 1).padStart(2, "0");
	 var yyyy = today.getFullYear();
	 $scope.todayDate = yyyy + "-" + mm + "-" + dd;
	 let d1 = new Date($scope.todayDate).getTime();
	 let d2 = new Date($scope.servers.IMSDASH_LIVE_DT).getTime();
	 if((d1 >=  d2) || ($scope.servers.IMS_TEST == 'Y')) {
		 $scope.imsLinkEnable = true;
	 } else {
		 $scope.imsLinkEnable = false;
	 }

	if ($().getConstant('COMP_REPORT_FLAG')){
        $scope.compFlag = $().getConstant('COMP_REPORT_FLAG');
	};
	$scope.showPostPP = function(){
		localStorage.setItem("isPostPP", "Y");
	}
	$scope.ucall = function () {
		ajax.get("/services/api/ustatus").then(function (resp) {
			if (resp && Object.keys(resp).length > 0) {
				$scope.udata = resp;
				shareData.udata = $scope.udata;
				$scope.validSP = false;
				// CR 29179A Changes Start - Taxpayer Eligibilty Validation for accessing specified premises
				if($scope.udata && $scope.udata.role && $scope.udata.role == "panLogin") {
					if($scope.udata.trnTaxPyrType && ($scope.udata.trnTaxPyrType == "TP" || $scope.udata.trnTaxPyrType == "NT")) {
						if($scope.udata.trnLiabCd && $scope.udata.trnLiabCd != null) {
							$scope.validSP = false;
						} else {
							$scope.validSP = true;
						}
					}
					$rootScope.$emit("validSP",  {
						"validSP": $scope.validSP
					});
				}
				// CR 29179A Changes End				
				/* CR#18614 and CR#20221 code changes start*/
				var bankTpTypes = ['TP','UN']; //CR-29095 removed 'O', 'NR' as updating bank account details should not be shown to NRTP/OIDAR Taxpayers
				var __compTypTaxpayer = $scope.udata.regType == "CO" && $scope.udata.appStatus == "A";

				
				 
				var __bnkNotAddTaxpayer = shareData.udata.bnkStat == "N" && $scope.udata.appStatus == "A" && $scope.udata.role == "login" && bankTpTypes.indexOf($scope.udata.utype) > -1;
				if(__compTypTaxpayer || __bnkNotAddTaxpayer) {
					var _triggerUdata = (__compTypTaxpayer && __bnkNotAddTaxpayer) ? "triggerUdataInBnk" : __compTypTaxpayer ?  "triggerUdataInComp" : "triggerUdataInBnk";
					if (__compTypTaxpayer) {
						__validateCompTP(_triggerUdata);
					}
					if(__bnkNotAddTaxpayer) { /* CR#20221 if condition */
						__validateBankTP(_triggerUdata)
					} 
				} 
				else {
					$rootScope.$emit("udata", {
						"udata": $scope.udata
					});
				}
				/* CR#18614 and CR#20221 code changes end*/
				if (shareData.udata.ASBS_STATE_CD) {
					$scope.getStatelist();
				}
				if ($scope.udata.appStatus == "C") {
					ajax.get("/services/api/taxpayer/CancellationStatus").then(function (resp) {
						if (resp && Object.keys(resp).length > 0) {
							$scope.udatasp = resp;
							shareData.udatasp = $scope.udatasp;
							$rootScope.$emit("udatasp", {
								"udatasp": $scope.udatasp
							});
						}
					});
				}
			}
		});

	}
	//einvoice login flag
	console.log("Login flag from einvoice is :",$().getConstant('flag'));
	$scope.hidemenu = false;
	console.log("value of hidemenu outside if is :",$scope.hidemenu);
		if ($().getConstant('flag')) {
			$scope.einvflag = $().getConstant('flag');
			if($scope.einvflag == "einvoice"){
				$scope.hidemenu = true;
				console.log("value of hidemenu inside if is :",$scope.hidemenu);
			}
			console.log("Login flag from einvoice inside if is :",$scope.einvflag);
    }
	    //To enable Einvoice
		if ($scope.servers['ENABLE_EINVOICE_DASHBOARD'] == "True") {
			console.log("Value of Enable Einv dashboard is :" + $scope.servers['ENABLE_EINVOICE_DASHBOARD']);
			$scope.enableEinv = true;
			// console.log("enableEinv"+enableEinv);
		} else {
			console.log("Value of Enable Einv dashboard is :" + $scope.servers['ENABLE_EINVOICE_DASHBOARD']);
			$scope.enableEinv = false;
			// console.log("enableEinv"+enableEinv);
		}

	/* CR#18614 code change start */
	var __validateCompTP = function (triggerUdata) {
		var payload = {
			"gstin": $scope.udata.gstin,
		};
		ajax.get('/services/auth/api/comp/validatecomp', payload).then(function (resp) {
			if (resp && Object.keys(resp).length > 0 && !resp.error) {
				$scope.compsp = resp;
				$scope.compsp.PAN = $scope.udata.gstin.substr(2, 10);
				$rootScope.$emit("compsp", {
					"compsp": $scope.compsp
				});
				if ($scope.compsp && $scope.compsp.thresholdLimAATO == "exceeded") {
					if($(".maskBank").length == 1) {
						$(".maskBank").remove();
					}
					//$("#main").prepend("<div class='maskComp' style='position:absolute;width:100%;height:100%;cursor:pointer'></div>");
				//	$(".nav.navbar-nav").css({
					//	"position": "relative",
					//	"z-index": "-1"
					//});
					//$scope.disableMenuShowTT();
					triggerPopup("maskComp");
				}
			}
			if (triggerUdata == "triggerUdataInComp") {
				$rootScope.$emit("udata", {
					"udata": $scope.udata
				});
			}
		});
	};
	var triggerPopup = function (showPP) {
		$("." + showPP).click(function (e) {
			if (showPP == "maskComp") {
				$scope.EnableCmpUsrPP();
			}
			else if(showPP == "maskBank"){
				$scope.popupMsg();
			}		
		});
	}
	$scope.disableMenuShowTT = function (toggleMsg) {
  		/* CR#22679 code changes start*/
        if ($scope.bankrsp && $scope.bankrsp.bankTimeEx == 'Y') {
            $scope.enableServices = true;
        }
  		/* CR#22679 code changes stop*/
		$scope.udata.disableMenu = true;
		var disableIds = ['myPrflDis', 'emblemDis', 'emblemTitDis', 'siteDis'];
		$('.menuList[data-toggle="tooltip"]').tooltip({
			title: toggleMsg ? toggleMsg : "",
			html: true,
		});
        /* CR#22679 code changes start */
        $('.smenu li[data-toggle="tooltip"]').tooltip({
            title: toggleMsg ? toggleMsg : "",
            html: true,
        });
        $('.smenu li.has-sub ul .isubmenu .leg .post[data-toggle="tooltip"]').tooltip({
            title: toggleMsg ? toggleMsg : "",
            html: true,
        });
        /* CR#22679 code changes stop */
		$('.breadcrumb').children('li').addClass('disabled');
    	/* CR#22679 code changes start */
        $('.breadcrumb').tooltip({
            title: toggleMsg ? toggleMsg : "",
            html: true,
        });
        /* CR#22679 code changes stop */
		$('.breadcrumb li a').css({
			'cursor': 'not-allowed',
			'text-decoration': 'none'
		});
		for (var i = 0; i < disableIds.length; i++) {
			var elementId = document.getElementById(disableIds[i]);
			if (elementId) {
				elementId.setAttribute('oncontextmenu', 'return false');
			}
		}
	};
	/* CR#18614 code changes end*/
	/* CR#20221 code changes start*/
	var __validateBankTP = function(triggerUdata) {
		var bankPayload = {
			"appStatus" : $scope.udata.appStatus,
			"bnkStatus" : $scope.udata.bnkStat
		};
		ajax.get('/services/auth/api/bankpop', bankPayload).then(function (resp) {
			if (resp && Object.keys(resp).length > 0 && !resp.error) {
				$scope.bankrsp = resp;
				$rootScope.$emit("bankrsp", {
					"bankrsp": $scope.bankrsp
				});
			}
			if(triggerUdata == "triggerUdataInBnk") {
				$rootScope.$emit("udata", {
					"udata": $scope.udata
				});
			}
		});	
	};
	$scope.clearPostPP = function (){
		if(localStorage.getItem("isPostPP") != null){
			localStorage.removeItem("isPostPP");
		}
	}
	$scope.popupMsg = function() {
		if (shareData.udata.bnkStat == 'N') {
			var isPopup = document.getElementById("confirmDlg");
			if(isPopup){
				return;
			}
			var idtype = "GSTIN";
			if (shareData.udata.utype == 'TR') {
				idtype = "Temporary ID";
			}
			var errMsg, submsg;
			errMsg = "Since you have crossed the time period to add the Bank Account Details. GSTIN Registration may be cancelled if such details are not filled at the earliest.";
			submsg = "Please add immediately to proceed further on the GST portal.";
			var conf = utilFunctions.createDialogue({
				"type": "fileamendment",
				"message": errMsg,
				"submsg": submsg,
				"title": "Dear Taxpayer,",
				"callback": "amendmentCall()",
				"ok_btn_title": "FILE AMENDMENT"
			});
			$('body').append($compile(conf)($scope));
			$("#confirmDlg").modal({
				show: true,
				backdrop: 'static'
			});
		}	
	};
	$scope.amendmentCall = function () {
		$scope.servers = $().getConstant('servers');
		switch (shareData.udata.utype) {
			case 'TP':
				$scope.amnURL = $scope.servers.GST_REGISTRATION_R1_URL + '/registration/auth/amend/noncore/business';
				break;
			case 'NREX':
			case 'NR':
			case 'TD':
			case 'TS':
			case 'O':
				$scope.amnURL = $scope.servers.GST_REGISTRATION_R1_URL + '/registration/auth/comnamend/noncore/basicdtls';
				break;
			case 'TR':
				$scope.amnURL = $scope.servers.GST_REGISTRATION_R1_URL + '/registration/auth/comnamend/noncore/bank';
				break;
		}
		FormSubmitter.submit($scope.amnURL, "POST", { 'amendFlag': 'Y' });
	}
	/* CR#20221 code changes end*/
	/* CR#18614 code changes start*/
	$scope.EnableCmpUsrPP = function () {
		var isthresholdLimit = $scope.compsp && ($scope.compsp.thresholdLimAATO == "lessTen" || $scope.compsp.thresholdLimAATO == "lessFive" || $scope.compsp.thresholdLimAATO == "exceeded");
		var isPopup = document.getElementById("compWdDlg");
		if (!$scope.compsp || !isthresholdLimit || isPopup) {
			return;
		}
		var compMsg, QntLimit;
		QntLimit = $scope.compsp.thresholdLimAATO == "lessTen" ? "10" : "5";
		var currency = $scope.compsp.turnOverAmount.toLocaleString('en-IN', {
			minimumFractionDigits: 2,
			maximumFractionDigits: 2
		});
		if ($scope.compsp.thresholdLimAATO == "lessTen" || $scope.compsp.thresholdLimAATO == "lessFive") {
			compMsg = "The Annual Aggregate Turnover for the Financial Year " + $scope.compsp.fy + " under the PAN (" + $scope.compsp.PAN + ") is " + QntLimit + " lakhs less the quantum specified. The Annual Aggregate Turnover under the PAN (" + $scope.compsp.PAN + ") is Rs." + currency + ". Kindly opt out of composition Levy if you expect the Annual Aggregate Turnover under the PAN to exceed the Quantum Specified.";
		} else if ($scope.compsp.thresholdLimAATO == "exceeded") {
			compMsg = "The Annual Aggregate Turnover for the Financial Year " + $scope.compsp.fy + " under the PAN (" + $scope.compsp.PAN + ") has already exceeded the quantum specified Kindly opt out of composition Levy.";
		}
		var conf = utilFunctions.createDialogue({
			"type": "compWithDraw",
			"message": compMsg,
			"callback": "withdrawComp()",
		});
		$('body').append($compile(conf)($scope));
		$("#compWdDlg").modal({
			show: true,
			backdrop: 'static'
		});
	};
	$scope.withdrawComp = function () {
		$("#compWdDlg").modal('hide');
		if ($scope.compsp.thresholdLimAATO == "exceeded") {
			FormSubmitter.submit($scope.servers.GST_REGISTRATION_R1_URL + "/registration/auth/wtdrwcomp", "POST", {
				"fy": $scope.compsp.fy,
				"thresholdLimAATO": $scope.compsp.thresholdLimAATO,
				"turnOverAmount": $scope.compsp.turnOverAmount,
				"isCompLogin": "Y"
			});
		}
	};
	/* CR#18614 code change end */
	$rootScope.$on('$routeChangeSuccess', function (event, current) {
		if($route.current && $route.current.$$route && $route.current.$$route.nostatus) {
			if($route.current.$$route.nostatus === true) {
				return ;
			} else {
				$scope.ucall();	
			}
		} else {
			$scope.ucall();
		}
	});
    $scope.redirectFn = function () {
        window.location.href = $scope.servers['GST_SERVICES_R1_URL']+"/services/auth/dashboard";
    } 
    
    
    $scope.getStatelist = function(){
        if(shareData.udata.stcd){
        if(shareData.udata.ASBS_STATE_CD){
            var stateCode =  shareData.udata.stcd;
            var stlist = shareData.udata.ASBS_STATE_CD;
            $scope.msmeStateCodesList = stlist.split(',');
            if ($scope.msmeStateCodesList.length > 0) {
                for(var i=0; i < $scope.msmeStateCodesList.length ; i++){
                    if(stateCode == $scope.msmeStateCodesList[i]){
                        $scope.showLink = true ;
                        //console.log($scope.showLink);
                    }
                }
            }     
        }
    }
    }
    
    
    $scope.msmeSoftwarePopup = function(){
          
        var conf = utilFunctions.createDialogue({
            "type": "Warning",
            "title": "Accounting And Billing Software Services",
            "message": "The download functionality is available to the Micro, Small and Medium Enterprises (MSMEs) having turnover less than 1.5 crores. Do you have turnover less than 1.5 crore?",
            "callback": "showSoftwareDetails()",
            "ok_btn_title": "Yes",
            "cancel_btn_title": "No",
            "cancelcallback": "destroyModal"
        });
        $('body').append($compile(conf)($scope));
        $("#confirmDlg").modal('show');
        
    }
	/* Optin for Quarterly Return link CR- 18145 */
	$scope.manageProfile = function () {
		window.location.href = $scope.servers['GST_RETURNS_R1_URL'] + "/returns/auth/managertnprofile";
	}
	$scope.smtwarningPopup = function () {

		var conf = utilFunctions.createDialogue({
			"type": "Warning",
			"title": "Warning",
			"message": "Link is not available for Suspended /Cancelled taxpayer",
			"callback": "destroyModal",
			"ok_btn_title": "OK",
			"cancel_btn_title": "Cancel",
			"cancelcallback": "destroyModal"
		});
		$('body').append($compile(conf)($scope));
		$("#confirmDlg").modal('show');

	}
	$scope.warningsvdpopup = function () {

		var conf = utilFunctions.createDialogue({
			"type": "Warning",
			"title": "Warning",
			"message": "You cannot file Core Amendment Application since your GSTIN is suspended.",
			"callback": "destroyModal",
			"ok_btn_title": "OK",
			"cancel_btn_title": "Cancel",
			"cancelcallback": "destroyModal"
		});
		$('body').append($compile(conf)($scope));
		$("#confirmDlg").modal('show');

	}
    $scope.showSoftwareDetails = function(){
        window.location.href = $scope.servers['GST_SERVICES_R1_URL']+"/services/auth/msmeSoftware";
    }
    
    $scope.destroyModal = function () {
        utilFunctions._destroyDialogue();
        $(".modal-backdrop").remove();
        $("body").removeClass("modal-open");
        $("body").css("padding-right", "0");
    };
    $scope.getPdf = function(type){
        var url;
        if(type == 1){
            url= $scope.servers['GST_TUTORIAL_R1_URL'] +"/offlineutilities/returns/NewGSTReturn_Normal.pdf";
            window.open(url, '_blank')
        }else if(type == 2){
             url= $scope.servers['GST_TUTORIAL_R1_URL'] +"/offlineutilities/returns/NewGSTReturn_Sahaj.pdf";
            window.open(url, '_blank')
        }else if(type == 3){
             url= $scope.servers['GST_TUTORIAL_R1_URL'] +"/offlineutilities/returns/NewGSTReturn_Sugam.pdf";
            window.open(url,'_blank')
        }
    }
    
}]).controller("sitemapctrl", function($scope, $rootScope, shareData){
    $scope.servers = $().getServers();
	$rootScope.$on("udata", function (event, mass) {
		if (mass && mass.udata) {
			$scope.udata = mass.udata;
		}
	});
	$rootScope.$on("udatasp", function (event, mass) {
        if (mass && mass.udatasp) {
            $scope.udatasp = mass.udatasp;
        }
    });
	// CR 29179A Changes Start - Taxpayer Eligibilty Validation for accessing specified premises
	$rootScope.$on("validSP", function(event, mass) {
		if (mass && mass.validSP) {
			$scope.validSP = mass.validSP;
		}else {
			$scope.validSP = false;
		}
	});
	// CR 29179A Changes End
}).controller("gstpdashboardctrl", function ($scope, $rootScope) {
	$rootScope.$on("udata", function (event, mass) {
		if (mass && mass.udata) {
			$scope.udata = angular.copy(mass.udata);
		}
	});
});
RouteProviderConfig.$inject = ['$routeProvider', '$locationProvider'];
myApp.config(RouteProviderConfig);

myApp.config(['$httpProvider', '$compileProvider', 'localStorageServiceProvider', function ($httpProvider, $compileProvider, localStorageServiceProvider) {
	$httpProvider.interceptors.push('httpTimeout');
	$httpProvider.interceptors.push('httpInterceptor');
	$compileProvider.debugInfoEnabled(false);
	localStorageServiceProvider.setPrefix('ls');
}]);
/***** env setup****/
myApp.provider('envService', function () {
	this.environment = 'development';
	this.set = function (environment) {
		this.environment = environment;
	};

	this.get = function () {
		return this.environment;
	};

	this.is = function (environment) {
		return (environment === this.environment);
	};
	this.$get = function () {
		return this;
	};
});
myApp.config(["envServiceProvider", function (envServiceProvider) {
	envServiceProvider.set('development');
}]);
myApp.config(["$provide", "$logProvider", "envServiceProvider", function ($provide, $logProvider, envServiceProvider) {

	$provide.decorator('$http', ["$delegate", "$q", function ($delegate, $q) {
		var pendingRequests = {},
			$http = $delegate,
			$duplicateRequestsFilter;

		function hash(str) {
			var h = 0,
				strlen = str.length,
				i, n;
			if (strlen === 0) {
				return h;
			}
			for (i = 0; i < strlen; i = i + 1) {
				n = str.charCodeAt(i);
				h = ((h << 5) - h) + n;
				h = h & h;
			}
			return h >>> 0;
		}

		function getRequestIdentifier(config) {
			var str = config.method + config.url;
			if (config.params && typeof config.params === 'object') {
				str += angular.toJson(config.params);
			}
			if (config.data && typeof config.data === 'object') {
				str += angular.toJson(config.data);
			}
			return hash(str);
		}

		$duplicateRequestsFilter = function (config) {

			//Ignore for this request?
			if (config.ignoreDuplicateRequest) {
				return $http(config);
			}

			//Get unique request identifier
			var identifier = getRequestIdentifier(config);

			//Check if such a request is pending already
			if (pendingRequests[identifier]) {
				if (config.rejectDuplicateRequest) {
					return $q.reject({
						data: '',
						headers: {},
						status: config.rejectDuplicateStatusCode || 400,
						config: config
					});
				}
				return pendingRequests[identifier];
			}

			//Create promise using $http and make sure it's reset when resolved
			pendingRequests[identifier] = $http(config)['finally'](function () {
				delete pendingRequests[identifier];
			});

			//Return promise
			return pendingRequests[identifier];
		};

		//Map rest of methods
		Object.keys($http).filter(function (key) {
			return (typeof $http[key] === 'function');
		}).forEach(function (key) {
			$duplicateRequestsFilter[key] = $http[key];
		});

		//Return it
		return $duplicateRequestsFilter;
    }]);

	if (envServiceProvider.get() === 'production') {
		$logProvider.debugEnabled(false);
	}

	if (envServiceProvider.get() === 'development') {
		$logProvider.debugEnabled(true);
	}

	$provide.decorator('$log', ["$delegate", function ($delegate) {
		var debugFn = $delegate.debug,
			warnFn = $delegate.warn,
			errFn = $delegate.error,
			infoFn = $delegate.info,
			logFn = $delegate.log,
			supplant = function (template, values, pattern) {
				pattern = pattern || /\{([^\{\}]*)\}/g;
				return template.replace(pattern, function (a, b) {
					var p = b.split('.'),
						r = values,
						s;
					try {
						for (s in p) {
							if (p.hasOwnProperty(s)) {
								r = r[p[s]];
							}
						}
					} catch (e) {
						r = e;
					}
					return (typeof r === 'string' || typeof r === 'number') ? r : a;
				});
			};

		$delegate.debug = function () {
			var args = [].slice.call(arguments),
				now = moment().format('DD-MM-YYYY hh:mm:ss A');
			if (typeof args[0] === 'object') {
				args[1] = now;
			} else {
				args[0] = supplant("{0} - {1}", [now, args[0]]);
			}
			if ($logProvider.debugEnabled()) {
				debugFn.apply(null, args);
			}
		};
		$delegate.warn = function () {
			var args = [].slice.call(arguments),
				now = moment().format('DD-MM-YYYY hh:mm:ss A');
			if (typeof args[0] === 'object') {
				args[1] = now;
			} else {
				args[0] = supplant("{0} - {1}", [now, args[0]]);
			}
			if ($logProvider.debugEnabled()) {
				warnFn.apply(null, args);
			}
		};
		$delegate.error = function () {
			var args = [].slice.call(arguments),
				now = moment().format('DD-MM-YYYY hh:mm:ss A');
			if (typeof args[0] === 'object') {
				args[1] = now;
			} else {
				args[0] = supplant("{0} - {1}", [now, args[0]]);
			}
			if ($logProvider.debugEnabled()) {
				errFn.apply(null, args);
			}
		};
		$delegate.log = function () {
			var args = [].slice.call(arguments),
				now = moment().format('DD-MM-YYYY hh:mm:ss A');
			if (typeof args[0] === 'object') {
				args[1] = now;
			} else {
				args[0] = supplant("{0} - {1}", [now, args[0]]);
			}
			if ($logProvider.debugEnabled()) {
				logFn.apply(null, args);
			}
		};
		$delegate.info = function () {
			var args = [].slice.call(arguments),
				now = moment().format('DD-MM-YYYY hh:mm:ss A');
			if (typeof args[0] === 'object') {
				args[1] = now;
			} else {
				args[0] = supplant("{0} - {1}", [now, args[0]]);
			}
			if ($logProvider.debugEnabled()) {
				infoFn.apply(null, args);
			}
		};
		return $delegate;
    }]);
}]);


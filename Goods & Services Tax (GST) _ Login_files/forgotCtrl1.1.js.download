            $().blockPage(true);
        }, function () {
            $().blockPage(false);
        }).then(function (response) {

            if (response.errorCode === "SWEB_9021") {
                if ($scope.forgotpass_2.$setPristine) {
                    $scope.forgotpass_2.$setPristine();
                    $scope.alertMsgLogin = false;
                    $scope.data.captcha = null;
                    $scope.oneClick3 = false;
                    $scope.captchaObj.refresh();
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                }
            } else if (response.errorCode === "SWEB_8000") {
                if ($scope.forgotpass_2.$setPristine) {
                     $scope.forgotpass_2.$setPristine();
                     $scope.alertMsgLogin = false;
                     $scope.data.captcha = null;
                     $scope.oneClick3 = false;
                     $scope.captchaObj.refresh();
                     $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
            	}
            } else if (response.message === "true" && response.successCode==null) {
                $scope.alertMsgLogin = true;
			          var msg = 'One-Time Password (OTP) has been successfully RESENT to your registered Email Address and Mobile Number';
                      var alert_dlg = utilFunctions.createAlert({
                                    "title": "Success : ",
                                    "type": "success",
                                    "message": msg
                                });
                     $('[name=errContainer]').empty().append($compile(alert_dlg)($scope));
				//$scope.data.captcha = null;
				$scope.captchaObj.refresh();
              }
	          else {
                 if (response.errorCode === "SWEB_9000") {
                    $('#fo-captcha1').focus();
					$scope.oneClick3 = false;
					$scope.captchaObj.refresh();
					$scope.alertMsgLogin = false;
                    $scope.errorMsg1 = "Enter valid letters shown in the image below";
                    }
		           }

        }, function (response) {

        });
    } else {

        $scope.alertMsgLogin = true;
    }
        
    };


    //forgotuser final submit
    $scope.usersubmit = function () {





        $scope.oneClick = true;


        ajax.post("/services/sendusername", {}, function () {
            $().blockPage(true);
        }, function () {
            $().blockPage(false);
        }).then(function (response) {


            if (response.errorCode === "SWEB_8000") {

                $scope.alertMsgLogin = false;
                $scope.oneClick = false;
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $('#fo-otp').focus();
                $window.scrollTo(0, 0);

            } else if (response.successCode === "SWEB_9020") {

                $scope.GenOtp = false;
                $scope.Security = true;
                $('#sec').hide();
                $('#sec1').show();
                $scope.alertMsgLogin = false;
                $('#alertMsg').removeClass('alert-danger');
                $('#alertMsg').removeClass('err');
                $('#alertMsg').addClass('alert-success');
                $scope.oneClick = true;


                $scope.frtusername = false;


                shareData.successCode = "SWEB_9020"
                $location.path('/login');
                $window.scrollTo(0, 0);


            } else if (response.errorCode === "SWEB_9021") {

                $scope.alertMsgLogin = false;
                $scope.oneClick = false;
                $('#fo-otp').focus();
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $window.scrollTo(0, 0);

            }
        }, function (response) {

        });


    };



    //forgotpass  generate OTP
	//$scope.newcaptcha=false;
    $scope.disableClick = function () {
         $scope.errorMsg2={};
         $scope.errorMsg2["login_error"] = false;
        if ($scope.forgotpass_1.user_name.$valid && $scope.forgotpass_1.cap.$valid) {
            $scope.oneClick = true;
            //$scope.newcaptcha=true;
            var requestparam = {
                username: $scope.data.fpusername,
                captcha: $scope.data.captcha
            };
            requestparam = JSON.stringify(requestparam);
            ajax.post("/services/checkusernamepwd", requestparam, function () {
                $().blockPage(true);
            }, function () {
                $().blockPage(false);
            }).then(function (response) {
                $scope.mobileNo = response.errorCode;
                if (response.message === "false") {
                    if ($scope.forgotpass_1.$setPristine) {
                        $scope.forgotpass_1.$setPristine();
                        $scope.forgotpass_1.user_name.$setDirty();
                        $('#fo-captcha').focus();
                        $scope.data.captcha = null;
                        $scope.captchaObj.refresh();
                        $scope.alertMsgLogin = false;
                        $scope.errorMsg1 = "OTP is not generated. Kindly click on Generate OTP";
                        $scope.oneClick = false;
                    }
                } else if (response.errorCode === "SWEB_8000") {
                    if ($scope.forgotpass_1.$setPristine) {
                        $scope.forgotpass_1.$setPristine();
                        $scope.captchaObj.refresh();
                        $scope.oneClick = false;
                        $scope.alertMsgLogin = false;
                        $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    }
                } else {
                    if ($scope.forgotpass_1.$setPristine) {
                        $scope.forgotpass_1.$setPristine();
                        $scope.forgotpass_1.user_name.$setDirty();
                        $scope.data.captcha = null;
                        $scope.captchaObj.refresh();

                        $scope.oneClick = false;
                        $scope.alertMsgLogin = false;

                        if (response.errorCode === "SWEB_9000") {
                            $scope.data.captcha = null;
                            $('#fo-captcha').focus();
                            $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                            $scope.data.captcha = null;
                        } else if (response.errorCode === "SWEB_9004") {
                            $scope.data.captcha = null;
                            $('#fo-user').focus();
                            $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                        } else if (response.errorCode === "SWEB_9007") {
                            $scope.data.captcha = null;
                            $('#fo-user').focus();

                            $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                        } else if (response.errorCode === "SWEB_9034") {
                            $scope.data.captcha = null;
                            $('#fo-user').focus();

                            $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                        } else if (response.errorCode === "SWEB_9036") {
                            $scope.errorMsg2["login_error"] = true;
                               $scope.forgotpass_1.$setPristine();
                               $scope.forgotpass_1.user_name.$setDirty();
                               $scope.errorMsg2["login_error_desc"] = $scope.trans["ERR_" + response.errorCode];
                        }else  {
                            if ($scope.forgotpass_1.$setPristine && response.successCode=="true") {
                                $scope.forgotpass_1.$setPristine();

                                $scope.data.em = response.url;

                                $scope.data.mob = response.message;


                                $scope.alertMsgLogin = true;
                                $scope.GenOtp = true;

                                var msg = 'One-Time Password (OTP) has been sent to your registered Email Address and Mobile Number';
                                var alert_dlg = utilFunctions.createAlert({
                                    "title": "Success : ",
                                    "type": "success",
                                    "message": msg
                                });
                                $('[name=errContainer]').append($compile(alert_dlg)($scope));

                                $scope.emailuser = false;
                                $scope.forgotuser = false;
                                $scope.UserPwd = false;
                                $scope.GenOtp = true;
                                $scope.Userdet = false;
                                $scope.UserPwd = false;
                                $scope.oneClick = true;
                                $scope.oneClick1 = false;
                                $scope.forgotpasswor = false;
                                $('#otp').removeClass("not-active");
                                $('.z1').removeClass("step-on");
                                $('.z1').addClass("step-done");
                                $('.z2').addClass("step-on");
                                $('#otp').addClass("on-page");
                                $('#upin').hide();
                                $('#upin1').show();
                                $('#fo-eotp').focus();
                            }
                        }

                    }
                }

            }, function (response) {

            });

        } else {
            $scope.alertMsgLogin = true;
            $('#fo-user').focus();
        }

     
     $scope.newregclick=function(){				
	 window.location.href = $scope.servers["GST_REGISTRATION_R1_URL"] + "/registration/";		 
		
	}
     
    };

    //forgotpass validate OTP
    $scope.procee = function () {
        $scope.errorMsg2={};
        $scope.errorMsg2["login_error"] = false;
        if ($scope.forgotpass_2.e_otp.$valid && $scope.forgotpass_2.cap.$valid) {
            $scope.oneClick1 = true;
            $scope.oneClick = false;
            var details = {

                otp: $scope.data.e_otp,
                captcha: $scope.data.captcha
                
            };

            var otpDetails = JSON.stringify(details);

            ajax.post("/services/validate/otp", otpDetails, function () {
                $().blockPage(true);
            }, function () {
                $().blockPage(false);
            }).then(function (response) {

                if (response.message === "true" &&  response.successCode==null) {
                    if ($scope.forgotpass_2.$setPristine) {
                        $scope.forgotpass_2.$setPristine();
                        $scope.oneClick = true;
                        $scope.oneClick1 = true;
                        $scope.oneClick2 = false;
                        $scope.alertMsgLogin = true;
                        $scope.question = true;
                        $scope.forgotpasswor = true;
                        $scope.GenOtp = true;
                        $scope.Security = false;
                        $scope.questions = true;
                        $scope.forgotpasswor = false;
                        $scope.GenOtp = false;
                        $scope.Security = false;
                        $('#otp').hide();
                        $('#otp1').show();
                        $('#newc').removeClass('not-active');
                        $('#newc').addClass('on-page');
                        $('.z2').removeClass('step-on');
                        $('.z2').addClass('step-done');
                        $('.z3').addClass('step-on');
                        $('#fo-pwd').focus();
                    }
					shareData.msg=response.message;

                } else if (response.errorCode === "SWEB_8000") {
                    if ($scope.forgotpass_2.$setPristine) {
                        $scope.forgotpass_2.$setPristine();
                        $scope.data.e_otp = null;
                        $scope.oneClick1 = false;
                        $scope.captchaObj.refresh();
                        $scope.alertMsgLogin = false;
                        $('#fo-eotp').focus();
                        $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];

                    }
                } else if (response.errorCode === "SWEB_9003") {
                    if ($scope.forgotpass_2.$setPristine) {
                        $scope.forgotpass_2.$setPristine();
                        $scope.data.captcha = null;
                        $scope.captchaObj.refresh();
                        $scope.data.e_otp = null;
                        $scope.oneClick1 = false;
                        $scope.alertMsgLogin = false;
                        $('#fo-eotp').focus();
                        $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    }
                } else if (response.errorCode === "SWEB_9021") {
                    if ($scope.forgotpass_2.$setPristine) {
                        $scope.forgotpass_2.$setPristine();
                        $scope.data.e_otp = null;
                        $scope.oneClick1 = false;
                        $scope.data.captcha = null;
                        $scope.captchaObj.refresh();
                        $scope.alertMsgLogin = false;
                        $('#fo-eotp').focus();
                        $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    }
                }
				else {
                         if (response.errorCode === "SWEB_9000") {
                            $('#fo-captcha1').focus();
							$scope.oneClick1 = false;
							$scope.captchaObj.refresh();
							$scope.alertMsgLogin = false;
                            $scope.errorMsg1 = "Enter valid letters shown in the image below";
                        }
				
				}
            }, function (response) {

            });
        } else {
            $scope.alertMsgLogin = true;
        }



    };

    //Forgot password final submit
    $scope.savePass = function () {
        $scope.oneClick = true;
        var details = {
            userName: $scope.data.fpusername,
            NewPassword: $scope.data.password,
            confirmPassword: $scope.data.repassword,
			message:shareData.msg
        };

        var userDetails = JSON.stringify(details);
        ajax.post("/services/resetpwd", userDetails, function () {
            $().blockPage(true);
        }, function () {
            $().blockPage(false);
        }).then(function (response) {

            if (response.successCode === "SWEB_9019") {
                $scope.oneClick = false;
                $scope.GenOtp = false;
                $scope.Userdet = false;
                $scope.question = false;
                $scope.forgotpasswor = false;
                $scope.frtpass = false;
                $scope.alertMsgLogin = false;
                $('#alertMsg').removeClass('alert-danger');
                $('#alertMsg').addClass('alert-success');
                $('#alertMsg').removeClass('err');
                $window.scrollTo(0, 0);
                $scope.fp_success = "SWEB_9019";
                shareData.successCode = "SWEB_9019";
                $location.path('/login');
            } else if (response.errorCode === "SWEB_9011") {
                $scope.alertMsgLogin = false;
                $scope.oneClick = false;
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $window.scrollTo(0, 0);
            } else if (response.errorCode === "SWEB_8000") {
                $scope.alertMsgLogin = false;
                $scope.oneClick = false;
                $('#fo-pwd').focus();
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $window.scrollTo(0, 0);
            } else if (response.errorCode === "SWEB_9017") {
                $scope.alertMsgLogin = false;
                $scope.oneClick = false;
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $window.scrollTo(0, 0);
            } else if (response.errorCode === "SWEB_9029") {
                $scope.alertMsgLogin = false;
                $scope.oneClick = false;
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $window.scrollTo(0, 0);
            } else if (response.errorCode === "SWEB_9027") {
                $scope.forgotpass_3.$setPristine();
                delete $scope.data.password
                delete $scope.data.repassword;
                $scope.alertMsgLogin = false;
                $scope.oneClick = false;
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $window.scrollTo(0, 0);
            }else if (response.errorCode === "SWEB_9003") {
                $scope.forgotpass_3.$setPristine();
                delete $scope.data.password
                delete $scope.data.repassword;
                $scope.alertMsgLogin = false;
                $scope.oneClick = false;
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $window.scrollTo(0, 0);
            }

        }, function (response) {

        });


    };

    //forgotpass new pass
    $scope.secProceed1 = function () {
        $scope.oneClick = true;
        $scope.oneClick1 = true;
        $scope.oneClick2 = false;

        if ($scope.forgotpass_3.pwd.$valid && $scope.forgotpass_3.repwd.$valid) {

            if ($scope.data.password === $scope.data.repassword) {
                if ($scope.forgotpass_3.$setPristine) {
                    $scope.forgotpass_3.$setPristine();
                    $scope.forgotpass_3.$submitted = false;

                    $scope.oneClick = true;
                    $scope.oneClick1 = true;
                    $scope.oneClick2 = false;
                    $scope.GenOtp = false;
                    $scope.question = true;
                    $scope.alertMsgLogin = true;
                    $('#newc').show();
                    $('#newc1').hide();
                    $('#city').focus();
                    $scope.savePass();
                }

            }


        } else {
            $scope.alertMsgLogin = true;
            $('#fo-pwd').focus();

        }


    };


}

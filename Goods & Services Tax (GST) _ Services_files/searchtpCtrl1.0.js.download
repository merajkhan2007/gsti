    /*svvd*/
    /*CR-19011 - Compliance Rating description*/
    function getComplianceRatingInfo() {
        $('.compliance-info [data-toggle="tooltip"]').attr("data-original-title", null);
        if ($('.compliance-info [data-toggle="tooltip"]').is(':visible')) {
            var compInfo = ($scope.trans && $scope.trans.INF_COMP_RATNG) ? $scope.trans.INF_COMP_RATNG : "";
            $('.compliance-info [data-toggle="tooltip"]').attr("data-original-title", compInfo);
        } else {
            setTimeout(getComplianceRatingInfo, 50);
        }
    }


    //full form of Corebusiness Activties from code value.
    function getNtrCoreBusDes (code){
		var result = "";
		if (code !='NA') {
			//shareData.corevalue = shareData.corevalue.data;
			var ntrbslist = code.split(":");
			var ntrbsmstr = shareData.corevalue;
			for (var cd in ntrbslist) {
				for (var i = 0; i < ntrbsmstr.length; i++) {
					if (ntrbsmstr[i].c == ntrbslist[cd]) {
						result += ntrbsmstr[i].n;
						if (ntrbsmstr[i].data && ntrbsmstr[i].data.length > 0) {
							result += ' - ';
							ntrbsmstr = ntrbsmstr[i].data;
						}
						break;
					}
				}
		}
		} else {
			result = "NA";
        }
        $scope.searchTaxpre_Payload ? $scope.searchTaxpre_Payload.ntcrbs = result : $scope.searchTax_Payload.ntcrbs = result;
		return result;
	}
    

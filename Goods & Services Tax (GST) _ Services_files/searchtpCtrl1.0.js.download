/*jslint browser: true*/
/*global $, jQuery, angular, myApp, fologinCtrl, $val*/
"use strict";
myApp.controller("searchtpctrl", searchtpctrl);



searchtpctrl.$inject = ['$scope', '$http', 'cache', '$rootScope', 'shareData', '$location', 'ajax', '$route', 'version', '$window', '$timeout', '$templateCache', '$log', 'utilFunctions', 'validations', 'NgTableParams', 'FormSubmitter'];


function searchtpctrl($scope, $http, cache, $rootScope, shareData, $location, ajax, $route, version, $window, $timeout, $templateCache, $log, utilFunctions, validations, NgTableParams, FormSubmitter) {

	//clearing params from url in searchtp
	if(Object.keys($location.search()).length){
		console.log("Redirect prevented to: " + "/error/notfound");		
	}
    $scope.path = $rootScope.path;
    
    // $scope.cookieEnabled = cookieEnabled;

    $scope.utilFunctions = utilFunctions;
    $scope.consent = true;
    $scope.alertMsgLoginSuccess = true;
    $scope.validations = validations;

    $scope.alertSuccess = true;
    $scope.alertMsgLogin = true;
    $scope.forgotUsername = true;
    $scope.forgtuser = true;
    $scope.data = {};
    $scope.forgotSucc = false;
    $scope.oneClick = false;
    $scope.forgotUsername = true;
    $scope.forgotpasswor = true;
    $scope.Userdet = true;
    $scope.UserPwd = true;
    $scope.validations = validations;
    //to generate otp
    $scope.GenOtp = false;
    $scope.ques = false;
    $scope.Security = false;
    $scope.frtusername = true;
    $scope.frtpass = true;
    $scope.login = true;
    $scope.errors = {};
    $scope.pro = function() {
        $scope.ques = true;
    };
    $scope.keywords="Jurisdictional Office";
    setInterval(function() {

        if (window.location.href.indexOf("/waiting") > 0) {
            $log.debug("serverbusy");

            ajax.get("/services/checksysavailability").then(function(response) {
                $log.debug(response);
                if (response.successCode === "true") {
                    console.log("Redirect prevented to: " + "/services/login");
                } else {
                    console.log("Redirect prevented to: " + "/services/waiting");
                }
            });
        }
    }, 60000);

    $scope.$on('$viewContentLoaded', function() {
        $window.scrollTo(0, 0);
        // angular.element(document.querySelector('[autofocus]')).focus();
    });

    /* for translation (start)*/

    /* init controller */
    utilFunctions.initCache();
    $scope.servers = $().getServers();
    $scope.trans = utilFunctions.initLanguage('services');
    $rootScope.$on("LangChanged", function(event, mass) {
        $scope.trans = utilFunctions.initLanguage('services');
    });
    $scope.$on('$viewContentLoaded', function() {
        $window.scrollTo(0, 0);
        angular.element(document.querySelector('[autofocus]')).focus();
    });
    /*init completed*/

    /* for translation (end)*/

    $rootScope.$emit("ChangeLang", {
        "lang": $scope.lang,
        "path": "services"
    });



    $scope.lodate = new Date();

    //for checking server availability
    $scope.consent = function() {



        $scope.lodate = new Date();
        ajax.get("/services/checksysavailability").then(function(response) {
            $log.debug(response);
            if (response.successCode === "true") {

                console.log("Redirect prevented to: " + "/services/newlogin");

            } else if (response.errorCode === "false") {
                console.log("Redirect prevented to: " + "/services/waiting");
            };
        });




    }

	if (cache.get("corbustype").length > 0) {
        shareData.corevalue = cache.get("corbustype");
    } else {
        ajax.get("/pages/services/data/corbustype.json").then(function (resp) {
            shareData.corevalue = resp.data;
            cache.set("corbustype", resp.data);
        }, function (err) {
            $scope.errors['corbustype'] = err.msg;
        });
	}

    //Track ARN

    //search TAXPAYER
    /*arabinda*/
    $scope.for_gstin = {};
    $scope.showBckBtn = false;
    //$rootScope.Modaldata = {};
    /**
     *  @author:    Arabinda Mishra
     *  @created:   Sep-Nov 2016
     *  @description: Serach TaxPayer Postlogin case for MVP 2(FO) for handling modals in controller injected $modal.
     *  @copyright: (c) Copyright by Infosys technologies
     **/
    /* $scope.showModal = false;
     $scope.open1 = function (modalData) {
         if (modalData === $scope.searchTax_Payload.members) {

             $scope.showModal = !$scope.showModal;
             $scope.Modaldata = $scope.searchTax_Payload.members;
             $scope.nameModal = "Promoters";

         } else {

             $scope.showModal = !$scope.showModal;
             $scope.Modaldata = $scope.naturedata;
             $scope.nameModal = "Nature";
         }


     };*/
    /**
     *  @author:    Arabinda Mishra
     *  @created:   Sep-Nov 2016
     *  @description: Serach TaxPayer Postlogin case for MVP 2(FO) implementation of server side pagination injected NgTable and                           $resource.
     *  @copyright: (c) Copyright by Infosys technologies
     **/


    $scope.busplaceaddr = {};
    $scope.searchTaxpayertable = function(gstnnum) {

        $scope.for_gstin.num = gstnnum;

        $scope.request = {

            "gstin": $scope.for_gstin.num
        };
        var config = {headers: {
            'Accept': 'application/json, text/plain',
			'Accept-Language': 'en-US,en;q=0.9',
			'Content-Type': 'application/json;charset=UTF-8'
        }
        }
        ajax.post($scope.servers["GST_PUBLICSERVICES_R1_URL"]+"/auth/api/search/tp/busplaces", $scope.request,config.headers).then(function(response) { 

            $scope.busplaceaddr = response;

            if (response.errorCode === "SWEB_8000") {
               
                    $scope.alertMsgLogin = false;
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    $scope.for_gstin.searchresult = false;

            } 
            else if(response.errorCode === "SWEB_9035"){
                  $scope.for_w_gst = true; //invalid gst
                    $scope.for_gstin.searchresult = false;
            }
            else {
			    if($scope.busplaceaddr.pradr!='NA'){
                $scope.busplaceaddr.pradr.type = 'p';
				$scope.busplaceaddr.adadr.splice(0, 0, $scope.busplaceaddr.pradr);
				}
				if ($scope.busplaceaddr && $scope.busplaceaddr.adadr && $scope.busplaceaddr.adadr != null && $scope.busplaceaddr.adadr != 'NA' ) {
					$scope.busiTable = new NgTableParams({
						page: 1,
						count: 10,

					}, {
						counts: [],
						dataset: $scope.busplaceaddr.adadr

					});
				}
            }

        });
        // var Api = $resource("/services/auth/search/tp/busPlaces?gstin=" + $scope.for_gstin.num); ///services/auth1/search/tp/busPlaces


    };



    /**
     *  @author:    Arabinda Mishra
     *  @created:   Sep-Nov 2016
     *  @description: Serach TaxPayer Postlogin case for MVP 2(FO) main.
     *  @copyright: (c) Copyright by Infosys technologies
     **/
    $scope.naturedata = [];
    $scope.nba1 = false;
    $scope.mbr = false;
    
    $scope.ctjPattern=false;
    $scope.stjPattern=false;     
	
	
	$scope.validateGstinUin = function(data) {
		if (data) {
			var gstinregx =/[0-9]{2}[a-zA-Z]{5}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[Zz1-9A-Ja-j]{1}[0-9a-zA-Z]{1}/, uinregx = /[0-9]{4}[A-Z]{3}[0-9]{5}[UO]{1}[N][A-Z0-9]{1}/, nrid =/[0-9]{4}[a-zA-Z]{3}[0-9]{5}[N][R][0-9a-zA-Z]{1}/,oidar_reg_ex = /[9][9][0-9]{2}[a-zA-Z]{3}[0-9]{5}[O][S][0-9a-zA-Z]{1}/, tdsregx = /[0-9]{2}[a-zA-Z]{4}[a-zA-Z0-9]{1}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[D]{1}[0-9a-zA-Z]{1}/, tcsregx = /[0-9]{2}[a-zA-Z]{5}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[C]{1}[0-9a-zA-Z]{1}/, aridregx= /[0-9]{12}[A][R][0-9a-zA-Z]{1}/,
			rfidregx= /[0-9]{12}[R][F][0-9a-zA-Z]{1}/,esidregx= /[0-9]{12}[E][S][0-9a-zA-Z]{1}/;
			if (gstinregx.test(data) || uinregx.test(data) || nrid.test(data) || oidar_reg_ex.test(data) || tcsregx.test(data) ||tdsregx.test(data) ||aridregx.test(data) || rfidregx.test(data) || esidregx.test(data)) {
				return true;
			}
		}
		return false;
	} 
	 
    $scope.searchTaxpayer = function() {
        $('.nav-tabs a[href="#partners"]').tab('show'); 
        if($scope.ewaybill_show || $scope.showfiling_show) {
            return;
        }
		if ($scope.for_gstin && (!$scope.for_gstin.num || $scope.for_gstin.num == "")) {
			$scope.searchtax.for_gstin.$setValidity("required", false);
			return;
		}
		if ($scope.for_gstin && !$scope.validateGstinUin($scope.for_gstin.num)) {
			$scope.searchtax.for_gstin.$setValidity("pattern", false);
			return;
        }
		$scope.showFinYearDropdown = false;
		$scope.errorMessage = false;
        $scope.for_gstin.searchresult = false;
        $scope.for_mand = false;
        $scope.for_w_gst = false;
        $scope.nba1 = false;
        $scope.mbr = false;
        $scope.noRecord = false;
        $scope.noLiabilityRecord = false;
        $scope.ewayData = false;
        $scope.fileData = false;
        $scope.liabilityData = false;
        $scope.ewayStatus_payload= false;
        $scope.filingStatus_payload=false;
        $scope.liabilityStatus_payload=false;
        //CR 20474 Part B changes
        $scope.profileData = false; 
        $scope.initial = true;
        $scope.userProfileDetails = false;
        //CR 20474 Part B changes
        $scope.taxpayerType = undefined;
		$scope.request = {

                "gstin": $scope.for_gstin.num
            };
        var config = {headers: {
            'Accept': 'application/json, text/plain',
			'Accept-Language': 'en-US,en;q=0.9',
			'Content-Type': 'application/json;charset=UTF-8'
        }
        }
		
        ajax.post($scope.servers["GST_PUBLICSERVICES_R1_URL"]+"/auth/api/search/tp", $scope.request,config.headers).then(function(response) { 
                if (response.errorCode === "SWEB_9034") {
                    $scope.for_mand = true;
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_9032" || response.errorCode === "SWEB_9035") {
                    $scope.for_w_gst = true; //invalid gst
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_9021") {

                    $scope.alertMsgLogin = false;

                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_8000") {

                    $scope.searchTax_Payload = response;
                    $scope.alertMsgLogin = false;
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];

                    $scope.for_gstin.searchresult = false;
                } else {
                   if(response.nba === 'NA' || !response.nba){
                        $scope.nba1 = true;
                    }
                    else {
                        response.nba = _.without(response.nba, null);
                    }
                    if(response.mbr === 'NA' || !response.mbr){
                        $scope.mbr = true;
                    }
                    $scope.alertMsgLogin = true;
                    $scope.searchTax_Payload = response;
					$scope.trdgstin = $scope.searchTax_Payload.gstin;
                    //CR 20474  Part B changes
                     $scope.userType = ((response && response.dty) ? response.dty : "");
                     $scope.userGstin = ((response && response.gstin) ? response.gstin : "");
                    //CR 20474  Part B changes end
                    //CR18285
                    if($scope.searchTax_Payload.ntcrbs)
                        getNtrCoreBusDes($scope.searchTax_Payload.ntcrbs);
                    var tprTy = ((response && response.dty) ? response.dty : "");
                    var gSts = ((response && response.sts) ? response.sts : "");
                    $scope.isCxSts = (/(^Cancelled$|^Cancelled due to expiry of registration period$|^Cancelled suo-moto$|^Cancelled on application of Taxpayer$|^Inactive$|^Suspended$|^Cancelled on Request of Taxpayer$)/g).test(gSts);
                    $scope.hasCompRating = false; //CR19011 need to hide compliance rating to All taxpayer.
                    $scope.hasAdhr = !(/(^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$|^Tax Deductor$|^Tax Collector \(Electronic Commerce Operator\)$|^Non Resident Online Services Provider$)/g).test(tprTy);
                    $scope.hasEkyc = !(/(^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$|^Tax Deductor$|^Tax Collector \(Electronic Commerce Operator\)$|^Non Resident Online Services Provider$)/g).test(tprTy);
                    //Masked the Aggregate turnover, Gross Taxable Income, % of Tax Payment in Cash fields for following Taxpayer for CR-19011.
                    $scope.hasATO = !(/(^Non Resident Online Services Provider$|^Tax Deductor$|^Input Service Distributor \(ISD\)$|^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$)/g).test(tprTy);
                    $scope.hasGTI = !(/(^Non Resident Online Services Provider$|^Tax Deductor$|^Input Service Distributor \(ISD\)$|^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$)/g).test(tprTy);
                    $scope.hasTPC = !(/(^Non Resident Online Services Provider$|^Tax Deductor$|^Input Service Distributor \(ISD\)$|^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$)/g).test(tprTy);
                    $scope.ctjPattern=false;
                    $scope.stjPattern=false;
                    $scope.tradeNameFlag=false;
                    var gstinregxp =/[0-9]{2}[a-zA-Z]{5}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[Zz1-9A-Ja-j]{1}[0-9a-zA-Z]{1}/;
                    var tdsregxp = /[0-9]{2}[a-zA-Z]{4}[a-zA-Z0-9]{1}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[D]{1}[0-9a-zA-Z]{1}/;
                    var tcsregxp = /[0-9]{2}[a-zA-Z]{5}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[C]{1}[0-9a-zA-Z]{1}/;
                    if(gstinregxp.test($scope.for_gstin.num) || tdsregxp.test($scope.for_gstin.num) || tcsregxp.test($scope.for_gstin.num)){
                    	$scope.tradeNameFlag=true;
                    }
                    var goodServiveURL_post = $scope.servers["GST_PUBLICSERVICES_R1_URL"]+"/auth/api/search/goodservice?gstin="+$scope.for_gstin.num;
                    getGoodsServices_value(goodServiveURL_post);

            		if(response.ctj){
            			$scope.ctjPattern=true;
                        var splitCTJVal = commonJurisdiction_split(response.ctj);
                        splitCTJVal.unshift("(JURISDICTION - CENTER)");
                        if((response.ctj).indexOf('Jurisdictional Office')>0){
                            response.admOfc= splitCTJVal;
            		}
                    else {
                            response.othrOfc = splitCTJVal;
                        }
                    }
            		if(response.stj){
            			$scope.stjPattern=true;
                        var splitSTJVal = commonJurisdiction_split(response.stj);
                        splitSTJVal.unshift("(JURISDICTION - STATE)");
                        if((response.stj).indexOf('Jurisdictional Office')>0){
                            response.admOfc= splitSTJVal ;
            		}
                    else {
                            response.othrOfc = splitSTJVal;
                        }
                    }
                    $scope.for_gstin.searchresult = true;
                    checkTaxpayerInfo(response.dty);
                    getComplianceRatingInfo();
                }
            });
    };


    /**
     *  @author:    Arabinda Mishra
     *  @created:   Sep-Nov 2016
     *  @description: Serach TaxPayer Prelogin case for MVP 2(FO).

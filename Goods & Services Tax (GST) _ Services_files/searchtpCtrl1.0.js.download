    $scope.getFilingData = function(year,loginType) {
		$scope.showfiling_show = true;
		$scope.errorMessage = false;
        $scope.filingStatus_payload=false;
        $scope.fileData = false;
        $scope.liabilityStatus_payload = false;
        $scope.liabilityData = false;
        $scope.ewayStatus_payload = false;  
        $scope.ewayData = false;
		$scope.noLiabilityRecord = false;
        $scope.noRecord = false;         
        $scope.profileData = false;
		$scope.userProfileDetails = false;
		$scope.request.fy = year.value;
        //CR 20474 PartB changes
        var filingURL ;
        if(loginType == "prelogin") {
            filingURL = "/services/api/search/taxpayerReturnDetails";
        } else {
            filingURL = $scope.servers["GST_PUBLICSERVICES_R1_URL"]+"/auth/api/search/taxpayerReturnDetails";
        }
            ajax.post(filingURL, $scope.request).then(function(response) {
                $scope.showfiling_show = false;
                $scope.for_gstin.captcha = null;
                $scope.for_cap_gst = false;
                if(loginType == "prelogin") {
                $scope.captchaObj.refresh();
                $scope.searchtaxp.$setPristine();
                }
                //$scope.searchtaxp.for_gstin.$setDirty();
                if (response.errorCode === "SWEB_9034") {
                    $scope.for_mand = true;
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_9032" || response.errorCode === "SWEB_9035") {
                    $scope.for_w_gst = true; //invalid gst
                    $scope.for_gstin.searchresult = false;
                    $scope.searchtaxp && $scope.searchtaxp.$setPristine();
                } else if (response.errorCode === "SWEB_9021") {

                    $scope.alertMsgLogin = false;
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    $scope.searchtaxp && $scope.searchtaxp.$setPristine();

                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_8000") {

                    $scope.alertMsgLogin = false;
                    $scope.searchtaxp && $scope.searchtaxp.$setPristine();
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_9000") {
                    if($scope.searchtaxp) {
                    $scope.searchtaxp.$setPristine();
                    // $scope.searchtaxp.for_gstin.$setDirty();
                    $scope.searchtaxp.cap.$setValidity("invalid_captcha", false);
                        $scope.captchaObj.refresh();
                    }
                    $scope.for_gstin.captcha = null;
                    $scope.captchaObj.refresh();
                    $scope.for_gstin.searchresult = false;
                } else {
                    $scope.fileData = true;
					if(response.filingStatus){
                        /*CR 17651 - filing table changes*/
                        var respArr = response.filingStatus[0];
                        var respArrWTordrBY = addOrderByValue(respArr);
                        console.log(respArrWTordrBY);
                        var makeNewArray = _.groupBy(respArrWTordrBY,"rtntype");
                        var filingValue = Object.keys(makeNewArray);
                        var typeArr = ["GSTR10","GSTR3B","GSTR1","CMP08","GSTR4","GSTR5","GSTR5A","GSTR6","GSTR7","GSTR8","GSTR11","GSTR9","GSTR9A","GSTR9C","GSTR4X","GSTR1A"];
                        var filterVal = function(val) {
                            return filingValue.indexOf(val) !== -1
                        }
                        var neededArr = typeArr.filter(filterVal); 
                        $scope.fillingValues = neededArr;
                            
                        $scope.filingStatus_payload = [makeNewArray];
					$scope.listOfStatus = new NgTableParams({
                    count: 10,
                    sorting: {
                        fy: 'asc'
                    }
                }, {
                        counts: [],
                        dataset: $scope.filingStatus_payload
                    });
					}
                    else{
                        $scope.noRecord = true;
                    }
                }


            });

    };

    //CR 20474 Part B changes
    $scope.getProfileData = function(loginType) {    
		$scope.showFinYearDropdown = false;
		$scope.errorMessage = false;
        $scope.filingStatus_payload=false;
        $scope.fileData = false;
        $scope.liabilityStatus_payload = false;
        $scope.liabilityData = false;
        $scope.ewayStatus_payload = false;  
        $scope.ewayData = false;
		$scope.noLiabilityRecord = false;
        $scope.noRecord = false;         
        $scope.profileData = true;
        var dt = new Date();
        var mon = dt.getMonth();
        $scope.currentFY = (mon < 3) ? dt.getFullYear() - 1 : dt.getFullYear();
        $scope.prevFY = parseInt($scope.currentFY) - 1;
        
        var fy = $scope.currentFY;
        if($scope.initial){
            fy = $scope.currentFY;
            var yr = "" + (parseInt(fy) + 1);
            $scope.finYear = fy + "-" + yr.substring(2);
            $scope.hyperlinkText = $scope.trans.HYP_PREV;           
            
        }
        else{
            fy = $scope.prevFY;
            var yr = "" + (parseInt(fy) + 1);
            $scope.finYear = fy + "-" + yr.substring(2);
            $scope.hyperlinkText = $scope.trans.HYP_CURR;            
            
        }
        
        
        var profileURL ;
        var param = {
            "gstin" : $scope.userGstin,
            "fy" : fy
        }
        
        if(loginType == "prelogin") {
            profileURL = "/services/api/search/taxpayerProfileDetails";
        } else {
            profileURL = $scope.servers["GST_SERVICES_R1_URL"]+"/services/auth/api/search/taxpayerProfileDetails";
        }
        
        ajax.get(profileURL, param).then(function(response) {
           // $().blockPage(false);
            if(loginType == "prelogin") {
                $scope.captchaObj.refresh();
                $scope.searchtaxp.$setPristine();
            }
            if (response.status == 1) {
                $scope.qtrList = { "Q1": 'Not Applicable', "Q2": 'Not Applicable', "Q3": 'Not Applicable', "Q4": 'Not Applicable' };
                $scope.profile = response.data.response;
                for (var x = 0; x < 4; x++) {
                    if (angular.isDefined($scope.profile[x])) {
                        var pref = $scope.profile[x].quarter;
                        $scope.qtrList[pref] = $scope.profile[x].preference === 'M' ? 'Monthly' : $scope.profile[x].preference === 'Q' ? 'Quarterly' : 'Not Applicable';
                    }
                }
                $scope.noProfileDetails = false;
                $scope.userProfileDetails = true;
                
            } else {
                if (response.error.errorCode && (response.error.errorCode === 'RT-NPRFA-1006' || response.error.errorCode === 'RT-NPRFA-1007')) {
                    $scope.noProfileMsg = response.error.message;
                    $scope.noProfileDetails = true;
                    $scope.userProfileDetails = true;
                }
                else if (response.error.errorCode && response.error.errorCode === 'RT-NPRFA-1005'){
                    $scope.noProfileMsg = $scope.trans.ERR_NOT_REG;
                    $scope.noProfileDetails = true;
                    $scope.userProfileDetails = true; 
                }
                else {
                    $scope.noProfileMsg = $scope.trans.ERR_NO_DETAILS;
                    $scope.noProfileDetails = true;
                    $scope.userProfileDetails = true;
                }
            }
        },
        function(err) {
            $().blockPage(false);
            $scope.noProfileMsg = $scope.trans.ERR_NO_DETAILS;
            $scope.noProfileDetails = true;
        });
        
    };

    $scope.changeYear = function(loginType) {
        if($scope.initial){
            $scope.initial = false;
        }
        else{
            $scope.initial = true; 
        }
        $scope.getProfileData(loginType);
    }
    //CR 20474 Part B changes End

    $scope.setTaxPeriod = function(financialYear){
        return financialYear.map(function(el){
            if(el['profile'] === 'Q'){
                let currTaxPeriod= el['taxperiod'].substr(0,3).toLowerCase();
                if(currTaxPeriod==='jan' || currTaxPeriod==='feb' || currTaxPeriod==='mar'){
                    el['taxperiod']='January-March';
                }
                else if(currTaxPeriod==='apr' || currTaxPeriod==='may' || currTaxPeriod==='jun'){
                    el['taxperiod']='April-June';
                }
                else if(currTaxPeriod==='jul' || currTaxPeriod==='aug'  ||  currTaxPeriod==='sep'){
                    el['taxperiod']='July-September';
                }
                else if(currTaxPeriod==='oct' || currTaxPeriod==='nov' || currTaxPeriod==='dec'){
                    el['taxperiod']='October-December';
                }
            }
            else{
                let currTaxPeriod= el['taxperiod'].substr(0,3).toLowerCase();
                switch(currTaxPeriod){
                    case 'jan':
                                el['taxperiod']="January";
                                break;
                    case 'feb':
                                el['taxperiod']="February";
                                break;
                    case 'mar':
                                el['taxperiod']="March";
                                break;
                    case 'apr':
                                el['taxperiod']="April";
                                break;
                    case 'may':
                                el['taxperiod']="May";
                                break;
                    case 'jun':
                                el['taxperiod']="June";
                                break;
                    case 'jul':
                                el['taxperiod']="July";
                                break;
                    case 'aug':
                                el['taxperiod']="August";
                                break;
                    case 'sep':
                                el['taxperiod']="September";
                                break;
                    case 'oct':
                                el['taxperiod']="October";
                                break;
                    case 'nov':
                                el['taxperiod']="November";
                                break;
                    case 'dec':
                                el['taxperiod']="December";
                                break;
                }
            }
            return el;
        });
    }

    $scope.sortTaxPeriod= function(financialYear){
        let order={
            "April":1,
            "April-June":2,
            "May":3,
            "June":4,
            "July":5,
            "July-September":6,
            "August":7,
            "Septempber":8,
            "October":9,
            "October-December":10,
            "November":11,
            "December":12,
            "January":13,
            "January-March":14,
            "February":15,
            "March":16
        }
        for(var i=0;i<financialYear.length;i++){
            var period=financialYear[i];
            period["order"]=order[period["taxperiod"]];
        }
        // for(let period of financialYear){
        //     period["order"]=order[period["taxperiod"]];
        // }
        financialYear.sort(function(first,second){return (first.order<second.order ? 1 : -1 )})
        // financialYear.sort((first,second)=>{return (first.order<second.order ? 1 : -1 )})
        return financialYear;
    }

    $scope.getLiabilityPaidPercentage = function() {
		$scope.showFinYearDropdown = false;
		$scope.errorMessage = false;
        $scope.noRecord = false;
        $scope.noLiabilityRecord = false;
        $scope.filingStatus_payload=false;
        $scope.ewayStatus_payload = false;
        $scope.liabilityStatus_payload = false;
        $scope.searchtax.$setPristine();
        $scope.ewayData = false;
		$scope.fileData = false;
        $scope.showfiling_show = false;
        $scope.showLiability_show=true;
        //CR 20474  Part B changes
        $scope.profileData = false; 
        $scope.initial = true; 
        $scope.userProfileDetails = false; 
        //CR 20474 Part B changes
        var URL = $scope.servers["GST_PUBLICSERVICES_R1_URL"]+"/auth/api/get/getLiabRatio?gstin="+$scope.for_gstin.num;
            ajax.get(URL).then(function(response) {
                $scope.showLiability_show = false;
				$scope.searchtax.$setPristine();
				if (response.errorCode === "SWEB_9034") {
					$scope.for_mand = true;
					$scope.for_gstin.searchresult = false;
				} else if (response.errorCode === "SWEB_9032" || response.errorCode === "SWEB_9035") {
					$scope.for_w_gst = true; //invalid gst
					$scope.for_gstin.searchresult = false;
					$scope.searchtax.$setPristine();
				} else if (response.errorCode === "SWEB_9021") {
					$scope.alertMsgLogin = false;
					$scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
					$scope.searchtax.$setPristine();
					$scope.for_gstin.searchresult = false;
				} else if (response.errorCode === "SWEB_8000") {
					$scope.alertMsgLogin = false;
					$scope.searchtax.$setPristine();
					$scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
					$scope.for_gstin.searchresult = false;
				}else{
                    $scope.liabilityData = true;
                    if(response["msg"]=== undefined) {
						$scope.currFyDtls = undefined;
						if(response.curdtls != undefined){
							$scope.currFyDtls=$scope.setTaxPeriod(response.curdtls);
                            $scope.currFyDtls=$scope.sortTaxPeriod($scope.currFyDtls);
						}
						$scope.prevFyDtls = undefined;
						if(response.prevdtls != undefined){
							$scope.prevFyDtls=$scope.setTaxPeriod(response.prevdtls);
                            $scope.prevFyDtls=$scope.sortTaxPeriod($scope.prevFyDtls);
						}
                        let cutfy = response.curfy.substr(2,2);
						let prvfy = response.prevfy.substr(2,2);
                        $scope.currFy=response.curfy + "-" + (parseInt(cutfy)+1);
                        $scope.prevFy=response.prevfy + "-" + (parseInt(prvfy)+1);
						$scope.currTotal="";
						if(response.curtotal != undefined){
							if(response.curtotal ==='-'){
								$scope.currTotal = response.curtotal;
							}else{
								const splittedArr= response.curtotal.split(".");
								const first= splittedArr[0];
								const second= splittedArr[1];
								if(second=== undefined || parseInt(second)===0){
									$scope.currTotal=first;
								}
								else {
									$scope.currTotal=first+"."+second;
								}
							}
						}
						$scope.prevTotal="";
						if(response.prevtotal != undefined){
							if(response.prevtotal ==='-'){
								$scope.prevTotal = response.prevtotal;
							}else{
								const splittedArr= response.prevtotal.split(".");
								const first= splittedArr[0];
								const second= splittedArr[1];
								if(second=== undefined || parseInt(second)===0){
									$scope.prevTotal=first;
								}
								else {
									$scope.prevTotal=first+"."+second;
								}
							}
						}
                        $scope.liabilityStatus_payload=true;
                    }
                    else{
                        $scope.noLiabilityRecord = true;
                    }
				}
            });
			 $scope.searchtax.$setPristine();
    };

   
    var addOrderByValue = function(data){
        var newData = data;
        var quarterArr = [
            {"taxp":"Apr-Jun","orderBy":1},
            {"taxp":"Jul-Sep","orderBy":2},
            {"taxp":"Oct-Dec","orderBy":3},
            {"taxp":"Jan-Mar","orderBy":4}
        ];
        var monthArr = [
            {"taxp":"April","orderBy": 1},
            {"taxp":"May", "orderBy": 2},
            {"taxp":"June", "orderBy": 3},
            {"taxp":"July","orderBy" : 4},{"taxp":"August","orderBy" : 5},{"taxp":"September","orderBy":6},{"taxp":"October","orderBy":7},{"taxp":"November","orderBy":8},{"taxp":"December","orderBy":9},{"taxp":"January","orderBy":10},{"taxp":"February","orderBy":11},{"taxp":"March","orderBy":12}]; 
        var combinedValue = quarterArr.concat(monthArr)
        for(var i=0; i<newData.length; i++){
            for(var j=0;j<combinedValue.length;j++) {
                if(newData[i].taxp == combinedValue[j].taxp){
                    newData[i].orderVal = combinedValue[j].orderBy;
                }
            }
        }
        return newData;
    }
    $scope.getEwayBillData = function() {
		$scope.showFinYearDropdown = false;
		$scope.errorMessage = false;
        $scope.ewaybill_show = true;
        $scope.filingStatus_payload = false;
		$scope.liabilityStatus_payload = false;
		$scope.noLiabilityRecord = false;
        $scope.noRecord = false;
        $scope.ewayResponse = [];
        $scope.searchtax.$setPristine();
        $scope.fileData = false;
		$scope.liabilityData = false;
        //CR 20474  Part B changes
        $scope.profileData = false; 
        $scope.initial = true; 
        $scope.userProfileDetails = false; 
        //CR 20474  Part B changes
        var EwayBillUrl = $scope.servers["GST_PUBLICSERVICES_R1_URL"]+"/auth/api/get/ewaybillhistory?gstin="+$scope.for_gstin.num;
        ajax.get(EwayBillUrl).then(function(response){
            $scope.searchtax.$setPristine();
            $scope.ewaybill_show = false;
            if (response.errorCode === "SWEB_9034") {
                $scope.for_mand = true;
                $scope.for_gstin.searchresult = false;
            } else if (response.errorCode === "SWEB_9032" || response.errorCode === "SWEB_9035") {
                $scope.for_w_gst = true; //invalid gst
                $scope.for_gstin.searchresult = false;
                $scope.searchtax.$setPristine();
            } else if (response.errorCode === "SWEB_9021") {
                $scope.alertMsgLogin = false;
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $scope.searchtax.$setPristine();
                $scope.for_gstin.searchresult = false;
            } else if (response.errorCode === "SWEB_8000") {
                $scope.alertMsgLogin = false;
                $scope.searchtax.$setPristine();
                $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                $scope.for_gstin.searchresult = false;
            }
            else if(response.errorCode === "EWB13510") {
                $scope.noRecord = response.message;
                $scope.ewayData = true;
            }
            else {
                populateEwayResponse(response);
                $scope.ewayStatus_payload= true;
                $scope.ewayData = true;
            }
        });
        function populateEwayResponse (value) {
            var blockDate = value.blockdate;
            var unblockDate = value.unblockdate;
            var checkFinalArr = [ ];
            if(blockDate && blockDate != "NA"){
                checkFinalArr[blockDate.length]= blockDate; 
            }
            if(unblockDate && unblockDate != "NA") {
                checkFinalArr[unblockDate.length]= unblockDate;
            }
            var checkBlcUnblcArr = checkFinalArr[checkFinalArr.length-1];
            for(var i=0; i<= checkBlcUnblcArr.length-1;i++){
                $scope.ewayResponse.push({"block": blockDate && blockDate[i], "unblock" : unblockDate && unblockDate[i] })
            }
            $scope.ewayBillTable = new NgTableParams({
                count: 10,
                sorting: {
                    fy: 'asc'
                }
            }, {
                    counts: [],
                    dataset: $scope.ewayResponse
                });
            $scope.searchtax.$setPristine();
        }
    };
    
    // Checking GstIn number while searching from Pan
    if($().getConstant('GstInNo') && $().getConstant('PanNum')){
       $scope.for_gstin = {};

       $scope.panNum = $().getConstant('PanNum'); // Assigning PAN number
       $scope.event = true; // To show the captcha 
       $scope.showCap = true;
       $scope.showBckBtn = true;
       if ($location.path().indexOf("auth") !== -1) {
           $scope.searchTaxpayer();
       }
    }

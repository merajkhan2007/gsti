     **/


    $scope.captchaObj = {

    };


    $scope.setPristine = function(form, ele, prop) {
        $scope[form][ele].$setValidity(prop, true);
    };

    $scope.showCap = true;
    $scope.showCap1 = function(cap) {
        if (cap) {

            $scope.searchtaxp.$setPristine();
            //$scope.trackarnpre.arn.$setDirty();
            $scope.showCap = true;
        }
    }
    $scope.nba = false;
    $scope.ewayStatus_payload = false;
   
    $scope.searchTaxpayerpre = function() {
        $scope.filingStatus_payload=false;
		$scope.errorMessage = false;
		
        if ($scope.for_gstin && (!$scope.for_gstin.num || $scope.for_gstin.num == "")) {
			$scope.searchtaxp.for_gstin.$setValidity("required", false);
			return;
		}
		if ($scope.for_gstin && !$scope.validateGstinUin($scope.for_gstin.num)) {
			$scope.searchtaxp.for_gstin.$setValidity("pattern", false);
			return;
		}
		$scope.showFinYearDropdown = false;
        $scope.for_gstin.searchresult = false;
        $scope.for_mand = false;
        $scope.for_w_gst = false;
        $scope.for_cap_gst = false;

        if ($scope.searchtaxp.$valid) {

            $scope.request = {

                "gstin": $scope.for_gstin.num,
                "captcha": $scope.for_gstin.captcha
            };

            ajax.post("/services/api/search/tp", $scope.request).then(function(response) {
                $scope.for_gstin.captcha = null;
                $scope.for_cap_gst = false;
                $scope.captchaObj.refresh();
                $scope.searchtaxp.$setPristine();
                //$scope.searchtaxp.for_gstin.$setDirty();
                if (response.errorCode === "SWEB_9034") {
                    $scope.for_mand = true;
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_9032" || response.errorCode === "SWEB_9035") {
                    $scope.for_w_gst = true; //invalid gst
                    $scope.for_gstin.searchresult = false;
                    $scope.searchtaxp.$setPristine();
                } else if (response.errorCode === "SWEB_9021") {

                    $scope.alertMsgLogin = false;
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    $scope.searchtaxp.$setPristine();

                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_8000") {

                    $scope.alertMsgLogin = false;
                    $scope.searchtaxp.$setPristine();
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_9000") {

                    $scope.searchtaxp.$setPristine();
                    // $scope.searchtaxp.for_gstin.$setDirty();
                    $scope.searchtaxp.cap.$setValidity("invalid_captcha", false);
                    $scope.for_gstin.captcha = null;
                    $scope.captchaObj.refresh();
                    $scope.for_gstin.searchresult = false;
                } else {
                    
                    if(response.nba === 'NA'){
                        $scope.nba = 'true';
                    }
                 
                    $scope.submitted = true;
                    $scope.alertMsgLogin = true;
                    $scope.searchTaxpre_Payload = response;
                    var tprTy = ((response && response.dty) ? response.dty : "");
                    var gSts = ((response && response.sts) ? response.sts : "");
                    $scope.isCxSts = (/(^Cancelled$|^Cancelled due to expiry of registration period$|^Cancelled suo-moto$|^Cancelled on application of Taxpayer$|^Inactive$|^Suspended$|^Cancelled on Request of Taxpayer$)/g).test(gSts);
                    $scope.hasAdhr = !(/(^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$|^Tax Deductor$|^Tax Collector \(Electronic Commerce Operator\)$|^Non Resident Online Services Provider$)/g).test(tprTy);
                    $scope.hasEkyc = !(/(^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$|^Tax Deductor$|^Tax Collector \(Electronic Commerce Operator\)$|^Non Resident Online Services Provider$)/g).test(tprTy);
                    var displayPattern =(response.ctj).match('Jurisdictional Office');
            		if(displayPattern){
            			$scope.ctjPattern=true;
            		}
            		var statePattern =(response.stj).match('Jurisdictional Office');
            		if(statePattern){
            			$scope.stjPattern=true;
            		}
					if(response.filingStatus){
                        for(var i =0;i<response.filingStatus[0].length;i++){
                            var parts = response.filingStatus[0][i].dof.split('/');
                            var date= new Date(parts[2], parts[1]-1, parts[0]); 
                            response.filingStatus[0][i].dof=date;
                            
                        }
					$scope.filingStatus_payload =response.filingStatus[0];
					$scope.listOfStatus = new NgTableParams({
                    count: 10,
                    sorting: {
                        fy: 'asc'
                    }
                }, {
                        counts: [],
                        dataset: $scope.filingStatus_payload
                    });
					}
                    $scope.searchtaxp.$setPristine();
                    $scope.for_gstin.searchresult = true;
                    $scope.showCap = false;
                    $scope.for_gstin.num = null;
                }


            });

        } 

    };
    
    //Adding below two functions for peak filing issue
    $scope.searchTaxpayerpreLogin = function() {
         $scope.fileData = false;
        $scope.noRecord = false;
        //CR 20474 Part B changes
        $scope.profileData = false; 
        $scope.initial = true;
        $scope.userProfileDetails = false; 
        //CR 20474 Part B changes
        $scope.filingStatus_payload=false;

		$scope.errorMessage = false;
        if ($scope.for_gstin && (!$scope.for_gstin.num || $scope.for_gstin.num == "")) {
			$scope.searchtaxp.for_gstin.$setValidity("required", false);
			return;
		}
		if ($scope.for_gstin && !$scope.validateGstinUin($scope.for_gstin.num)) {
			$scope.searchtaxp.for_gstin.$setValidity("pattern", false);
			return;
		}
		$scope.showFinYearDropdown = false;
        $scope.for_gstin.searchresult = false;
        $scope.for_mand = false;
        $scope.for_w_gst = false;
        $scope.for_cap_gst = false;
        $scope.nba = false;
        $scope.taxpayerType = undefined;

        if ($scope.searchtaxp.$valid) {

            $scope.request = {

                "gstin": $scope.for_gstin.num,
                "captcha": $scope.for_gstin.captcha
            };

            ajax.post("/services/api/search/taxpayerDetails", $scope.request).then(function(response) {
                $scope.for_gstin.captcha = null;
                $scope.for_cap_gst = false;
                $scope.captchaObj.refresh();
                $scope.searchtaxp.$setPristine();
                //$scope.searchtaxp.for_gstin.$setDirty();
                if (response.errorCode === "SWEB_9034") {
                    $scope.for_mand = true;
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_9032" || response.errorCode === "SWEB_9035") {
                    $scope.for_w_gst = true; //invalid gst
                    $scope.for_gstin.searchresult = false;
                    $scope.searchtaxp.$setPristine();
                } else if (response.errorCode === "SWEB_9021") {

                    $scope.alertMsgLogin = false;
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    $scope.searchtaxp.$setPristine();

                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_8000") {

                    $scope.alertMsgLogin = false;
                    $scope.searchtaxp.$setPristine();
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.errorCode];
                    $scope.for_gstin.searchresult = false;
                } else if (response.errorCode === "SWEB_9000") {

                    $scope.searchtaxp.$setPristine();
                    // $scope.searchtaxp.for_gstin.$setDirty();
                    $scope.searchtaxp.cap.$setValidity("invalid_captcha", false);
                    $scope.for_gstin.captcha = null;
                    $scope.captchaObj.refresh();
                    $scope.for_gstin.searchresult = false;
                }  else if (response.error && response.error.error_cd && (response.error.error_cd === "SWEB_9032" || response.error.error_cd === "SWEB_9035")) {
                    $scope.for_w_gst = true; //invalid gst
					//$scope.errorMsg1 = $scope.trans["ERR_" + response.error.error_cd];
                    $scope.for_gstin.searchresult = false;
                    $scope.searchtaxp.$setPristine();
                
                }  else if (response.error && response.error.error_cd &&(response.error.error_cd === "SWEB_8000")) {
					$scope.alertMsgLogin = false;
                    $scope.searchtaxp.$setPristine();
                    $scope.errorMsg1 = $scope.trans["ERR_" + response.error.error_cd];
                    $scope.for_gstin.searchresult = false; 
                }
                else {
                    
                    if(response.nba === 'NA' || !response.nba){
                        $scope.nba = true;
                    }
                    else {
                        response.nba = _.without(response.nba, null);
                    }
                 
                    //CR 20474  Part B changes
                    $scope.userType = ((response && response.dty) ? response.dty : "");
                    $scope.userGstin = ((response && response.gstin) ? response.gstin : "");
                    //CR 20474  Part B changes end
                    $scope.submitted = true;
                    $scope.alertMsgLogin = true;

                    $scope.searchTaxpre_Payload = response;
					 $scope.trdgstin = $scope.searchTaxpre_Payload.gstin;
                    //CR18285
                    if($scope.searchTaxpre_Payload.ntcrbs)
                        getNtrCoreBusDes($scope.searchTaxpre_Payload.ntcrbs);

                    var tprTy = ((response && response.dty) ? response.dty : "");
                    var gSts = ((response && response.sts) ? response.sts : "");
                    $scope.isCxSts = (/(^Cancelled$|^Cancelled due to expiry of registration period$|^Cancelled suo-moto$|^Cancelled on application of Taxpayer$|^Inactive$|^Suspended$|^Cancelled on Request of Taxpayer$)/g).test(gSts);
                    $scope.hasAdhr = !(/(^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$|^Tax Deductor$|^Tax Collector \(Electronic Commerce Operator\)$|^Non Resident Online Services Provider$)/g).test(tprTy);
                    $scope.hasEkyc = !(/(^United Nation Body$|^Consulate or Embassy of Foreign Country$|^Other Notified Persons$|^Tax Deductor$|^Tax Collector \(Electronic Commerce Operator\)$|^Non Resident Online Services Provider$)/g).test(tprTy);
                    $scope.ctjPattern=false;
                    $scope.stjPattern=false;
                    $scope.tradeFlag=false;
                    var gstinregexp =/[0-9]{2}[a-zA-Z]{5}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[Zz1-9A-Ja-j]{1}[0-9a-zA-Z]{1}/;
                    var tdsregexp = /[0-9]{2}[a-zA-Z]{4}[a-zA-Z0-9]{1}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[D]{1}[0-9a-zA-Z]{1}/;
                    var tcsregexp = /[0-9]{2}[a-zA-Z]{5}[0-9]{4}[a-zA-Z]{1}[1-9A-Za-z]{1}[C]{1}[0-9a-zA-Z]{1}/;
                    if(gstinregexp.test($scope.for_gstin.num) || tdsregexp.test($scope.for_gstin.num) || tcsregexp.test($scope.for_gstin.num)){
                    	$scope.tradeFlag=true;
                    }
                    var goodServiveURL_pre = "/services/api/search/goodservice?gstin="+$scope.for_gstin.num;
                    getGoodsServices_value(goodServiveURL_pre);

            		if(response.ctj){
            			$scope.ctjPattern=true;
                        var splitCTJVal = commonJurisdiction_split(response.ctj);
                        splitCTJVal.unshift("(JURISDICTION - CENTER)");
                        if((response.ctj).indexOf('Jurisdictional Office')>0){
                            response.admOfc= splitCTJVal;
            		}
                    else {
                            response.othrOfc = splitCTJVal;
                        }
                    }
            		
            		if(response.stj){
            			$scope.stjPattern=true;
                        var splitSTJVal = commonJurisdiction_split(response.stj);
                        splitSTJVal.unshift("(JURISDICTION - STATE)")
                        if((response.stj).indexOf('Jurisdictional Office')>0){
                            response.admOfc= splitSTJVal;
            		}
                    else {
                            response.othrOfc = splitSTJVal;
                        }
                    }
                    $scope.searchtaxp.$setPristine();
                    $scope.for_gstin.searchresult = true;
                    $scope.showCap = false;
                    $scope.for_gstin.num = null;
                    checkTaxpayerInfo(response.dty);
                }


            });
        } 

    };
    var commonJurisdiction_split = function(data) {
        var removeVal = data.replace("(Jurisdictional Office)", "")
        var splitValue = removeVal.split(',');
        return splitValue;
    }
    function checkTaxpayerInfo(payload) {
        $scope.taxpayerType = payload || $scope.taxpayerType;
        var taxPayerDesc;
        var taxpayerJSON = $scope.taxpayerJson.data;
        $('.taxpayer-info [data-toggle="tooltip"]').attr("data-original-title", null);
        for(var i =0;i<taxpayerJSON.length;i++) {
            if(taxpayerJSON[i].c == $scope.taxpayerType) {
                taxPayerDesc = taxpayerJSON[i].desc;
        } 
        }
        if ($('.taxpayer-info [data-toggle="tooltip"]').is(':visible')) {
            $('.taxpayer-info [data-toggle="tooltip"]').attr("data-original-title", taxPayerDesc);
        } else {
            setTimeout(checkTaxpayerInfo, 50);
        }
    };
    $scope.getTaxpayerTypes = function() {
        ajax.get('/pages/services/data/taxpayertypes.json', {}, {}, function() {
            $().blockPage(true);
            $scope.errors.regTypes = "Loading..";
        }, function() {
            $().blockPage(false);
        }).then(function(response) {
            $scope.taxpayerJson = response;
        });
    };
    $scope.getTaxpayerTypes();
    var getGoodsServices_value = function(url) {
        $scope.modifiedGDServArr = [];
         ajax.get(url).then(function(response) {
            if(response.errorCode === "SWEB_9021" || response.errorCode === "SWEB_8000") {
                $scope.goodServErrMsg = $scope.trans["ERR_" + response.errorCode] || response.message;
            }
            else if(response.errorCode === "FO8000") {
                $scope.goodServErrMsg = undefined;
            }
            else {
                GoodServiceArray(response);
                $scope.goodServErrMsg = undefined;
            }
        });
        function GoodServiceArray(value) {
            var goodsVal = value.bzgddtls;
            var serviceVal = value.bzsdtls;
            var checkMaxArr = [ ];
            if(goodsVal){
                checkMaxArr[goodsVal.length]= goodsVal;
            }
            if(serviceVal) {
                checkMaxArr[serviceVal.length]= serviceVal;
            }
            var checkGDServArr =checkMaxArr[checkMaxArr.length-1];
            for(var i=0; i<= checkGDServArr.length-1;i++){
                $scope.modifiedGDServArr.push({"Goods": goodsVal && goodsVal[i], "Service" : serviceVal && serviceVal[i]})
            }
        }
    }

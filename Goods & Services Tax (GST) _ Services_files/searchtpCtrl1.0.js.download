    //trade name CR to fetch additional trade names
    $scope.getaddltrdnm = function(){ 
        var requestcy = {
            "gstin": $scope.trdgstin         
        };
        ajax.get("api/search/getAddlTrdNams",requestcy, {}, function() {
            $().blockPage(true);
        }, function() {
            $().blockPage(false);
        }).then(function (response) {
			if(response && response.length && response.length>0){
            $scope.addltrdnm = response;
			}
			else if(response==null){
				$scope.addltrdnm=[];
			}
            $("#addltrd").modal('show');
        },function(err){
            console.log(err);
        });
    }
